<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VocabMaster - Demo Pages</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }

        .page-link {
            transition: all 0.3s ease;
        }

            .page-link:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            }
    </style>
</head>
<body class="bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 min-h-screen">
    <div class="container mx-auto px-4 py-16">
        <!-- Header -->
        <div class="text-center mb-16">
            <h1 class="text-5xl font-bold text-gray-900 mb-4">
                📚 VocabMaster
            </h1>
            <p class="text-xl text-gray-600">

            </p>
        </div>

        <!-- Pages Grid -->
        <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Login Page -->
            <a class="page-link block bg-white rounded-xl shadow-lg p-8 hover:shadow-2xl" asp-area="" asp-controller="Home" asp-action="Login">
                <div class="flex items-center gap-4 mb-4">
                    <div class="bg-blue-100 p-3 rounded-lg">
                        <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-gray-900">Đăng nhập</h3>
                        <p class="text-sm text-gray-500">Login & Register</p>
                    </div>
                </div>
                <p class="text-gray-600">Trang đăng nhập và đăng ký tài khoản</p>
            </a>

            <!-- Dashboard Page -->
            <a class="page-link block bg-white rounded-xl shadow-lg p-8 hover:shadow-2xl" asp-area="" asp-controller="Home" asp-action="Dashboard">
                <div class="flex items-center gap-4 mb-4">
                    <div class="bg-green-100 p-3 rounded-lg">
                        <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-gray-900">Dashboard</h3>
                        <p class="text-sm text-gray-500">Trang chủ</p>
                    </div>
                </div>
                <p class="text-gray-600">Trang tổng quan với thống kê và tiến độ học tập</p>
            </a>

            <!-- Vocabulary Page -->
            <a class="page-link block bg-white rounded-xl shadow-lg p-8 hover:shadow-2xl" asp-area="" asp-controller="Home" asp-action="Vocabulary">
                <div class="flex items-center gap-4 mb-4">
                    <div class="bg-purple-100 p-3 rounded-lg">
                        <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-gray-900">Bộ từ vựng</h3>
                        <p class="text-sm text-gray-500">Vocabulary Sets</p>
                    </div>
                </div>
                <p class="text-gray-600">Quản lý các bộ từ vựng của bạn</p>
            </a>

            <!-- Vocabulary Detail Page -->
            <a class="page-link block bg-white rounded-xl shadow-lg p-8 hover:shadow-2xl" asp-area="" asp-controller="Home" asp-action="Vocab_detail">
                <div class="flex items-center gap-4 mb-4">
                    <div class="bg-indigo-100 p-3 rounded-lg">
                        <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-gray-900">Chi tiết bộ từ</h3>
                        <p class="text-sm text-gray-500">Vocabulary Detail</p>
                    </div>
                </div>
                <p class="text-gray-600">Xem danh sách từ vựng trong bộ</p>
            </a>

            <!-- Learning Page -->
            <a class="page-link block bg-white rounded-xl shadow-lg p-8 hover:shadow-2xl" asp-area="" asp-controller="Home" asp-action="Learning">
                <div class="flex items-center gap-4 mb-4">
                    <div class="bg-orange-100 p-3 rounded-lg">
                        <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-gray-900">Học tập</h3>
                        <p class="text-sm text-gray-500">Learning Flashcards</p>
                    </div>
                </div>
                <p class="text-gray-600">Học từ vựng với flashcard 3D animation</p>
            </a>

            <!-- Progress Page -->
            <a class="page-link block bg-white rounded-xl shadow-lg p-8 hover:shadow-2xl" asp-area="" asp-controller="Home" asp-action="Progress">
                <div class="flex items-center gap-4 mb-4">
                    <div class="bg-pink-100 p-3 rounded-lg">
                        <svg class="w-8 h-8 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-gray-900">Tiến độ</h3>
                        <p class="text-sm text-gray-500">Progress Tracking</p>
                    </div>
                </div>
                <p class="text-gray-600">Theo dõi tiến độ học tập với biểu đồ</p>
            </a>
        </div>


    </div>
</body>
</html>

        <main role="main" class="pb-3">
            @RenderBody()
        </main>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Vocab_LearningApp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
