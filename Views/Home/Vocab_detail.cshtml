@using System
@using System.Linq
@using System.Text.Json
@model Vocab_LearningApp.Models.ViewModels.DeckDetailPageViewModel
@{
    Layout = null;
    ViewData["Title"] = "Chi tiết bộ từ";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chi tiết bộ từ - VocabMaster</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 text-slate-900">
    <header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur">
        <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
            <a asp-controller="Home" asp-action="Vocabulary" class="flex items-center gap-3">
                <span class="text-2xl">📚</span>
                <div>
                    <p class="text-sm font-bold uppercase tracking-wide text-indigo-600">VocabMaster</p>
                    <p class="text-xs text-slate-500">Deck detail</p>
                </div>
            </a>
            <nav class="hidden items-center gap-6 md:flex">
                <a asp-controller="Home" asp-action="Dashboard" class="text-slate-600 hover:text-slate-900">Dashboard</a>
                <a asp-controller="Home" asp-action="Vocabulary" class="text-slate-600 hover:text-slate-900">Bộ từ vựng</a>
                <a asp-controller="Home" asp-action="Progress" class="text-slate-600 hover:text-slate-900">Tiến độ</a>
            </nav>
            <div class="flex items-center gap-3">
                <img src="@(Model.User.AvatarUrl ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(Model.User.FullName)}&background=4f46e5&color=fff")" alt="Avatar" class="h-10 w-10 rounded-full object-cover ring-2 ring-indigo-100">
                <a asp-controller="Home" asp-action="Learning" asp-route-deckId="@Model.Deck.Id" class="rounded-2xl bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Học ngay</a>
            </div>
        </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <section class="mb-8 rounded-[2rem] bg-gradient-to-br from-slate-900 via-indigo-900 to-fuchsia-900 p-6 text-white shadow-xl">
            <div class="grid gap-6 lg:grid-cols-[1.4fr_1fr] lg:items-center">
                <div>
                    <div class="flex flex-wrap items-center gap-2">
                        <span class="rounded-full bg-white/15 px-3 py-1 text-xs font-semibold">@Model.Deck.Tags</span>
                        <span class="rounded-full @(Model.Deck.IsPublic ? "bg-emerald-400/20" : "bg-white/15") px-3 py-1 text-xs font-semibold">@(Model.Deck.IsPublic ? "Public" : "Private")</span>
                    </div>
                    <h1 class="mt-4 text-3xl font-black sm:text-4xl">@Model.Deck.Title</h1>
                    <p class="mt-3 max-w-3xl text-white/85">@(Model.Deck.Description ?? "Bộ từ này chưa có mô tả.")</p>
                    <div class="mt-6 flex flex-wrap gap-3">
                        <a asp-controller="Home" asp-action="Learning" asp-route-deckId="@Model.Deck.Id" class="rounded-2xl bg-white px-5 py-3 text-sm font-semibold text-indigo-700 hover:bg-indigo-50">Bắt đầu học</a>
                        <button type="button" onclick="openDeckModal()" class="rounded-2xl border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Sửa bộ từ</button>
                        <button type="button" onclick="openVocabularyModal()" class="rounded-2xl border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Thêm từ</button>
                        <a href="/api/decks/@Model.Deck.Id/export?format=csv" class="rounded-2xl border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Export CSV</a>
                        <a href="/api/decks/@Model.Deck.Id/export?format=xlsx" class="rounded-2xl border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Export Excel</a>
                    </div>
                </div>
                <div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-1 xl:grid-cols-3">
                    <div class="rounded-2xl bg-white/15 p-4 backdrop-blur"><p class="text-sm text-white/80">Tổng từ</p><p class="mt-2 text-3xl font-black">@Model.Deck.TotalWords</p></div>
                    <div class="rounded-2xl bg-white/15 p-4 backdrop-blur"><p class="text-sm text-white/80">Đã học</p><p class="mt-2 text-3xl font-black">@Model.Deck.LearnedWords</p></div>
                    <div class="rounded-2xl bg-white/15 p-4 backdrop-blur"><p class="text-sm text-white/80">Cần ôn</p><p class="mt-2 text-3xl font-black">@Model.Deck.DueWords</p></div>
                </div>
            </div>
            <div class="mt-6">
                <div class="mb-2 flex justify-between text-sm text-white/80">
                    <span>Tiến độ học tập</span>
                    <span class="font-semibold">@Model.Deck.ProgressPercentage%</span>
                </div>
                <div class="h-3 overflow-hidden rounded-full bg-white/15">
                    <div class="h-3 rounded-full bg-white" style="width:@Model.Deck.ProgressPercentage%"></div>
                </div>
            </div>
        </section>

        <form method="get" asp-action="Vocab_detail" class="mb-6 rounded-[2rem] bg-white p-4 shadow-sm ring-1 ring-slate-200">
            <input type="hidden" name="deckId" value="@Model.Deck.Id" />
            <div class="grid gap-4 md:grid-cols-[1.3fr_1fr_1fr_auto]">
                <input type="text" name="search" value="@Model.Search" placeholder="Tìm kiếm từ vựng..." class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                <select name="status" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(Model.Status) ? "selected" : null)">Tất cả trạng thái</option>
                    <option value="new" selected="@(Model.Status == "new" ? "selected" : null)">Chưa học</option>
                    <option value="learning" selected="@(Model.Status == "learning" ? "selected" : null)">Đang học</option>
                    <option value="reviewing" selected="@(Model.Status == "reviewing" ? "selected" : null)">Cần ôn</option>
                    <option value="mastered" selected="@(Model.Status == "mastered" ? "selected" : null)">Thành thạo</option>
                </select>
                <select name="sort" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                    <option value="az" selected="@(string.IsNullOrWhiteSpace(Model.Sort) || Model.Sort == "az" ? "selected" : null)">A-Z</option>
                    <option value="za" selected="@(Model.Sort == "za" ? "selected" : null)">Z-A</option>
                    <option value="newest" selected="@(Model.Sort == "newest" ? "selected" : null)">Mới nhất</option>
                    <option value="oldest" selected="@(Model.Sort == "oldest" ? "selected" : null)">Cũ nhất</option>
                </select>
                <button type="submit" class="rounded-2xl bg-indigo-600 px-5 py-3 font-semibold text-white hover:bg-indigo-700">Lọc</button>
            </div>
        </form>

        @if (Model.Deck.VocabularyItems.Any())
        {
            <div class="space-y-4">
                @foreach (var item in Model.Deck.VocabularyItems)
                {
                    var statusKey = item.Status?.ToLowerInvariant() ?? "new";
                    var badgeClass = statusKey switch
                    {
                        "mastered" => "bg-emerald-100 text-emerald-700",
                        "learning" => "bg-orange-100 text-orange-700",
                        "reviewing" => "bg-yellow-100 text-yellow-700",
                        _ => "bg-sky-100 text-sky-700"
                    };
                    var statusLabel = statusKey switch
                    {
                        "mastered" => "Thành thạo",
                        "learning" => "Đang học",
                        "reviewing" => item.IsDue ? "Cần ôn" : "Đang ôn",
                        _ => "Chưa học"
                    };

                    <article class="rounded-[2rem] bg-white shadow-sm ring-1 ring-slate-200 transition hover:shadow-lg">
                        <div class="p-6">
                            <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
                                <div class="flex-1">
                                    <div class="flex flex-wrap items-center gap-3">
                                        <h2 class="text-2xl font-black">@item.Word</h2>
                                        <span class="text-sm text-slate-500">@item.Pronunciation</span>
                                        @if (!string.IsNullOrWhiteSpace(item.AudioUrl))
                                        {
                                            <a href="@item.AudioUrl" target="_blank" class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600 hover:bg-slate-200">Audio</a>
                                        }
                                    </div>
                                    <p class="mt-3 text-slate-600"><strong>Nghĩa:</strong> @(item.MeaningVi ?? "Chưa cập nhật")</p>
                                    <p class="mt-2 text-slate-600"><strong>Mô tả:</strong> @(item.DescriptionEn ?? "Chưa cập nhật")</p>
                                    <p class="mt-2 text-slate-600"><strong>Ví dụ:</strong> <em>@(item.ExampleSentence ?? "Chưa có ví dụ")</em></p>
                                    <p class="mt-2 text-slate-600"><strong>Collocation:</strong> @(item.Collocations ?? "Chưa cập nhật")</p>
                                    <p class="mt-2 text-slate-600"><strong>Từ liên quan:</strong> @(item.RelatedWords ?? "Chưa cập nhật")</p>
                                    <p class="mt-3 text-sm text-slate-500">SRS: EF @item.EaseFactor.ToString("0.00") • Lặp @item.Repetitions • Lịch ôn @(item.NextReviewDate?.ToString("dd/MM/yyyy") ?? "chưa có")</p>
                                </div>
                                <div class="flex flex-col items-end gap-2">
                                    <span class="rounded-full px-3 py-1 text-xs font-semibold @badgeClass">@statusLabel</span>
                                    @if (item.IsDue)
                                    {
                                        <span class="text-xs font-semibold text-orange-600">Đến hạn ôn</span>
                                    }
                                </div>
                            </div>
                            <div class="mt-5 flex flex-wrap gap-2">
                                <a asp-controller="Home" asp-action="Learning" asp-route-deckId="@Model.Deck.Id" class="rounded-xl bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">@(item.Status == "new" ? "Học ngay" : "Học lại")</a>
                                <button type="button" onclick='openVocabularyModal(@Html.Raw(JsonSerializer.Serialize(new { id = item.Id, word = item.Word, pronunciation = item.Pronunciation ?? string.Empty, partOfSpeech = item.PartOfSpeech, meaningVi = item.MeaningVi ?? string.Empty, descriptionEn = item.DescriptionEn ?? string.Empty, exampleSentence = item.ExampleSentence ?? string.Empty, collocations = item.Collocations ?? string.Empty, relatedWords = item.RelatedWords ?? string.Empty, note = item.Note ?? string.Empty, imageUrl = item.ImageUrl ?? string.Empty, audioUrl = item.AudioUrl ?? string.Empty })))' class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-50">Sửa</button>
                                <button type="button" onclick="deleteVocabulary(@item.Id)" class="rounded-xl border border-rose-200 px-4 py-2 text-sm font-semibold text-rose-700 hover:bg-rose-50">Xóa</button>
                            </div>
                        </div>
                    </article>
                }

                @if (Model.Deck.Pagination.TotalPages > 1)
                {
                    <div class="flex flex-wrap items-center justify-center gap-2 py-6">
                        <a asp-action="Vocab_detail" asp-route-deckId="@Model.Deck.Id" asp-route-search="@Model.Search" asp-route-status="@Model.Status" asp-route-sort="@Model.Sort" asp-route-pageNumber="@(Model.Deck.Pagination.Page - 1)" class="rounded-xl border border-slate-200 px-4 py-2 hover:bg-slate-50 @(Model.Deck.Pagination.HasPreviousPage ? string.Empty : "pointer-events-none opacity-50")">Trước</a>
                        @for (var pageNumber = 1; pageNumber <= Model.Deck.Pagination.TotalPages; pageNumber++)
                        {
                            <a asp-action="Vocab_detail" asp-route-deckId="@Model.Deck.Id" asp-route-search="@Model.Search" asp-route-status="@Model.Status" asp-route-sort="@Model.Sort" asp-route-pageNumber="@pageNumber" class="rounded-xl px-4 py-2 @(pageNumber == Model.Deck.Pagination.Page ? "bg-indigo-600 text-white" : "border border-slate-200 hover:bg-slate-50")">@pageNumber</a>
                        }
                        <a asp-action="Vocab_detail" asp-route-deckId="@Model.Deck.Id" asp-route-search="@Model.Search" asp-route-status="@Model.Status" asp-route-sort="@Model.Sort" asp-route-pageNumber="@(Model.Deck.Pagination.Page + 1)" class="rounded-xl border border-slate-200 px-4 py-2 hover:bg-slate-50 @(Model.Deck.Pagination.HasNextPage ? string.Empty : "pointer-events-none opacity-50")">Sau</a>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="rounded-[2rem] border border-dashed border-slate-300 bg-white p-10 text-center text-slate-500 shadow-sm">Không có từ nào khớp bộ lọc hiện tại.</div>
        }
    </main>

    <div id="deck-modal" class="hidden fixed inset-0 z-50 items-center justify-center bg-black/50 px-4">
        <div class="w-full max-w-2xl rounded-[2rem] bg-white p-6 shadow-2xl">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-wide text-indigo-600">Deck form</p>
                    <h3 class="mt-1 text-2xl font-bold">Sửa bộ từ</h3>
                </div>
                <button type="button" onclick="window.vocabApp.closeModal('deck-modal')" class="rounded-full bg-slate-100 px-3 py-1 text-slate-600 hover:bg-slate-200">×</button>
            </div>
            <form id="deck-form" class="mt-6 grid gap-4">
                <input type="hidden" id="deck-id" value="@Model.Deck.Id">
                <div>
                    <label class="mb-2 block text-sm font-medium text-slate-700">Tên bộ từ</label>
                    <input type="text" id="deck-title-input" value="@Model.Deck.Title" required class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                </div>
                <div>
                    <label class="mb-2 block text-sm font-medium text-slate-700">Mô tả</label>
                    <textarea id="deck-description-input" rows="4" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">@Model.Deck.Description</textarea>
                </div>
                <div class="grid gap-4 sm:grid-cols-2">
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Tags</label>
                        <input type="text" id="deck-tags-input" value="@Model.Deck.Tags" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                    </div>
                    <label class="flex items-center gap-2 self-end rounded-2xl bg-slate-50 px-4 py-3 text-sm text-slate-700">
                        <input type="checkbox" id="deck-public-input" @(Model.Deck.IsPublic ? "checked" : null) class="rounded border-slate-300 text-indigo-600 focus:ring-indigo-500"> Public deck
                    </label>
                </div>
                <div class="flex flex-wrap justify-end gap-3 pt-2">
                    <button type="button" onclick="window.vocabApp.closeModal('deck-modal')" class="rounded-2xl border border-slate-200 px-5 py-3 font-semibold text-slate-600 hover:bg-slate-50">Hủy</button>
                    <button type="submit" class="rounded-2xl bg-indigo-600 px-5 py-3 font-semibold text-white hover:bg-indigo-700">Lưu</button>
                </div>
            </form>
        </div>
    </div>

    <div id="vocab-modal" class="hidden fixed inset-0 z-50 items-center justify-center bg-black/50 px-4">
        <div class="w-full max-w-3xl rounded-[2rem] bg-white p-6 shadow-2xl">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-wide text-emerald-600">Vocabulary form</p>
                    <h3 id="vocab-modal-title" class="mt-1 text-2xl font-bold">Thêm từ mới</h3>
                </div>
                <button type="button" onclick="window.vocabApp.closeModal('vocab-modal')" class="rounded-full bg-slate-100 px-3 py-1 text-slate-600 hover:bg-slate-200">×</button>
            </div>
            <form id="vocab-form" class="mt-6 grid gap-4">
                <input type="hidden" id="vocab-id">
                <div class="grid gap-4 md:grid-cols-2">
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Word</label>
                        <input type="text" id="vocab-word" required class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200">
                    </div>
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Pronunciation</label>
                        <input type="text" id="vocab-pronunciation" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200">
                    </div>
                </div>
                <div class="grid gap-4 md:grid-cols-3">
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Part of speech</label>
                        <select id="vocab-pos" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200">
                            <option value="">Không chọn</option>
                            <option value="1">Noun</option>
                            <option value="2">Verb</option>
                            <option value="3">Adjective</option>
                            <option value="4">Adverb</option>
                            <option value="5">Phrase</option>
                        </select>
                    </div>
                    <div class="md:col-span-2">
                        <label class="mb-2 block text-sm font-medium text-slate-700">Meaning (VI)</label>
                        <input type="text" id="vocab-meaning" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200">
                    </div>
                </div>
                <div>
                    <label class="mb-2 block text-sm font-medium text-slate-700">Description (EN)</label>
                    <textarea id="vocab-description" rows="3" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200"></textarea>
                </div>
                <div>
                    <label class="mb-2 block text-sm font-medium text-slate-700">Example sentence</label>
                    <textarea id="vocab-example" rows="3" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200"></textarea>
                </div>
                <div class="grid gap-4 md:grid-cols-2">
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Collocation</label>
                        <input type="text" id="vocab-collocations" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200">
                    </div>
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Related words</label>
                        <input type="text" id="vocab-related" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200">
                    </div>
                </div>
                <div class="grid gap-4 md:grid-cols-2">
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Note</label>
                        <input type="text" id="vocab-note" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200">
                    </div>
                    <div class="grid gap-4 sm:grid-cols-2">
                        <div>
                            <label class="mb-2 block text-sm font-medium text-slate-700">Image URL</label>
                            <input type="url" id="vocab-image" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200">
                        </div>
                        <div>
                            <label class="mb-2 block text-sm font-medium text-slate-700">Audio URL</label>
                            <input type="url" id="vocab-audio" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200">
                        </div>
                    </div>
                </div>
                <div class="flex flex-wrap justify-end gap-3 pt-2">
                    <button type="button" onclick="window.vocabApp.closeModal('vocab-modal')" class="rounded-2xl border border-slate-200 px-5 py-3 font-semibold text-slate-600 hover:bg-slate-50">Hủy</button>
                    <button type="submit" class="rounded-2xl bg-emerald-600 px-5 py-3 font-semibold text-white hover:bg-emerald-700">Lưu từ</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openDeckModal() {
        window.vocabApp.openModal('deck-modal');
        }

        function openVocabularyModal(vocab) {
        const modalTitle = document.getElementById('vocab-modal-title');
        const vocabId = document.getElementById('vocab-id');

        if (vocab && vocab.id) {
        modalTitle.textContent = 'Chỉnh sửa từ vựng';
        vocabId.value = vocab.id;
        document.getElementById('vocab-word').value = vocab.word || '';
        document.getElementById('vocab-pronunciation').value = vocab.pronunciation || '';
        document.getElementById('vocab-pos').value = vocab.partOfSpeech || '';
        document.getElementById('vocab-meaning').value = vocab.meaningVi || '';
        document.getElementById('vocab-description').value = vocab.descriptionEn || '';
        document.getElementById('vocab-example').value = vocab.exampleSentence || '';
        document.getElementById('vocab-collocations').value = vocab.collocations || '';
        document.getElementById('vocab-related').value = vocab.relatedWords || '';
        document.getElementById('vocab-note').value = vocab.note || '';
        document.getElementById('vocab-image').value = vocab.imageUrl || '';
        document.getElementById('vocab-audio').value = vocab.audioUrl || '';
        } else {
        modalTitle.textContent = 'Thêm từ mới';
        vocabId.value = '';
        document.getElementById('vocab-form').reset();
        }

        window.vocabApp.openModal('vocab-modal');
        }

        async function deleteVocabulary(vocabularyId) {
        if (!confirm('Bạn chắc chắn muốn xóa từ này?')) {
        return;
        }

        const { response, payload } = await window.vocabApp.requestJson(`/api/decks/vocabularies/${vocabularyId}`, {
        method: 'DELETE'
        });

        if (!response.ok) {
        window.vocabApp.toast(payload?.message || 'Không thể xóa từ.', 'error');
        return;
        }

        window.vocabApp.toast('Đã xóa từ vựng.', 'success');
        window.vocabApp.safeReload();
        }

        document.getElementById('deck-form').addEventListener('submit', async function (event) {
        event.preventDefault();

        const payload = {
        title: document.getElementById('deck-title-input').value.trim(),
        description: document.getElementById('deck-description-input').value.trim() || null,
        tags: document.getElementById('deck-tags-input').value.trim() || null,
        isPublic: document.getElementById('deck-public-input').checked
        };

        const { response, payload: result } = await window.vocabApp.requestJson(`/api/decks/@Model.Deck.Id`, {
        method: 'PUT',
        body: JSON.stringify(payload)
        });

        if (!response.ok) {
        window.vocabApp.toast(result?.message || 'Không thể lưu bộ từ.', 'error');
        return;
        }

        window.vocabApp.toast(result?.message || 'Đã cập nhật bộ từ.', 'success');
        window.vocabApp.closeModal('deck-modal');
        window.vocabApp.safeReload();
        });

        document.getElementById('vocab-form').addEventListener('submit', async function (event) {
        event.preventDefault();

        const vocabId = document.getElementById('vocab-id').value;
        const payload = {
        word: document.getElementById('vocab-word').value.trim(),
        pronunciation: document.getElementById('vocab-pronunciation').value.trim() || null,
        partOfSpeech: document.getElementById('vocab-pos').value ? Number(document.getElementById('vocab-pos').value) : null,
        meaningVi: document.getElementById('vocab-meaning').value.trim() || null,
        descriptionEn: document.getElementById('vocab-description').value.trim() || null,
        exampleSentence: document.getElementById('vocab-example').value.trim() || null,
        collocations: document.getElementById('vocab-collocations').value.trim() || null,
        relatedWords: document.getElementById('vocab-related').value.trim() || null,
        note: document.getElementById('vocab-note').value.trim() || null,
        imageUrl: document.getElementById('vocab-image').value.trim() || null,
        audioUrl: document.getElementById('vocab-audio').value.trim() || null
        };

        const url = vocabId ? `/api/decks/vocabularies/${vocabId}` : `/api/decks/@Model.Deck.Id/vocabularies`;
        const method = vocabId ? 'PUT' : 'POST';
        const { response, payload: result } = await window.vocabApp.requestJson(url, {
        method,
        body: JSON.stringify(payload)
        });

        if (!response.ok) {
        window.vocabApp.toast(result?.message || 'Không thể lưu từ vựng.', 'error');
        return;
        }

        window.vocabApp.toast(result?.message || 'Đã lưu từ vựng.', 'success');
        window.vocabApp.closeModal('vocab-modal');
        window.vocabApp.safeReload();
        });
    </script>
</body>
</html>