@using System
@using System.Linq
@using System.Collections.Generic
@using System.Text.Json
@model Vocab_LearningApp.Models.ViewModels.DeckDetailPageViewModel

@{
    Layout = null;
    ViewData["Title"] = Model.Deck.Title;

    var deck = Model.Deck;
    var items = deck.VocabularyItems ?? Array.Empty<Vocab_LearningApp.Models.Domain.VocabularyItem>();
    var userFullName = Model.User?.FullName ?? "User";
    var avatarUrl = Model.User?.AvatarUrl
        ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(userFullName)}&background=4f46e5&color=fff";

    var selectedStatus = string.IsNullOrWhiteSpace(Model.Status) ? string.Empty : Model.Status;
    var selectedSort = string.IsNullOrWhiteSpace(Model.Sort) ? "newest" : Model.Sort;
    var searchValue = Model.Search ?? string.Empty;

    var deckData = new
    {
        id = deck.Id,
        title = deck.Title,
        description = deck.Description ?? string.Empty,
        tags = deck.Tags ?? string.Empty,
        isPublic = deck.IsPublic
    };
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.Deck.Title - VocabMaster</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 text-slate-900">
    <header class="sticky top-0 z-40 border-b border-slate-200 bg-white/90 backdrop-blur">
        <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
            <div class="flex items-center gap-3">
                <a asp-controller="Home" asp-action="Vocabulary" class="rounded-2xl border border-slate-200 px-3 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-50">
                    ← Quay lại
                </a>
                <div>
                    <p class="text-sm font-bold uppercase tracking-wide text-indigo-600">VocabMaster</p>
                    <p class="text-xs text-slate-500">Quản lý từ trong bộ</p>
                </div>
            </div>

            <nav class="hidden items-center gap-6 md:flex">
                <a asp-controller="Home" asp-action="Dashboard" class="text-slate-600 hover:text-slate-900">Dashboard</a>
                <a asp-controller="Home" asp-action="Vocabulary" class="font-semibold text-indigo-600">Bộ từ vựng</a>
                <a asp-controller="Home" asp-action="Progress" class="text-slate-600 hover:text-slate-900">Tiến độ</a>
            </nav>

            <div class="flex items-center gap-3">
                <img src="@avatarUrl"
                     alt="Avatar"
                     class="h-10 w-10 rounded-full object-cover ring-2 ring-indigo-100">
            </div>
        </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <section class="rounded-[2rem] bg-gradient-to-br from-indigo-600 via-violet-600 to-fuchsia-600 p-6 text-white shadow-xl">
            <div class="grid gap-6 lg:grid-cols-[1.4fr_0.8fr] lg:items-center">
                <div>
                    <div class="flex flex-wrap items-center gap-2">
                        <span class="rounded-full bg-white/15 px-3 py-1 text-xs font-semibold">@((deck.IsPublic) ? "Public" : "Private")</span>
                        <span class="rounded-full bg-white/15 px-3 py-1 text-xs font-semibold">
                            @(string.IsNullOrWhiteSpace(deck.Tags)
                                ? "No tag"
                                : deck.Tags.Split(',').FirstOrDefault()?.Trim())
                        </span>
                    </div>

                    <h1 class="mt-3 text-3xl font-black sm:text-4xl">@deck.Title</h1>
                    <p class="mt-3 max-w-3xl text-white/85">@((string.IsNullOrWhiteSpace(deck.Description)) ? "Bộ từ này chưa có mô tả." : deck.Description)</p>

                    <div class="mt-5 flex flex-wrap gap-3">
                        <button type="button"
                                onclick='openDeckModal(@Html.Raw(JsonSerializer.Serialize(deckData)))'
                                class="rounded-2xl bg-white px-4 py-2.5 text-sm font-semibold text-indigo-700 hover:bg-slate-100">
                            Sửa bộ
                        </button>

                        <button type="button"
                                onclick="openVocabularyModal()"
                                class="rounded-2xl bg-slate-950/25 px-4 py-2.5 text-sm font-semibold text-white hover:bg-slate-950/35">
                            + Thêm từ mới
                        </button>

                        <a asp-controller="Home"
                               asp-action="Learning"
                               asp-route-deckId="@deck.Id"
                               class="rounded-2xl bg-emerald-500 px-4 py-2.5 text-sm font-semibold text-white hover:bg-emerald-600">
                            Học ngay
                        </a>

                        <a asp-action="Vocab_detail"
                               asp-route-deckId="@deck.Id"
                               asp-route-format="csv"
                               asp-route-export="true"
                               class="hidden">
                        </a>
                    </div>
                </div>

                <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-2">
                    <div class="rounded-2xl bg-white/15 p-4 backdrop-blur">
                        <p class="text-sm text-white/80">Tổng từ</p>
                        <p class="mt-2 text-3xl font-black">@deck.TotalWords</p>
                    </div>
                    <div class="rounded-2xl bg-white/15 p-4 backdrop-blur">
                        <p class="text-sm text-white/80">Đang học</p>
                        <p class="mt-2 text-3xl font-black">@deck.LearnedWords</p>
                    </div>
                    <div class="rounded-2xl bg-white/15 p-4 backdrop-blur">
                        <p class="text-sm text-white/80">Cần ôn</p>
                        <p class="mt-2 text-3xl font-black">@deck.DueWords</p>
                    </div>
                    <div class="rounded-2xl bg-white/15 p-4 backdrop-blur">
                        <p class="text-sm text-white/80">Tiến độ</p>
                        <p class="mt-2 text-3xl font-black">@deck.ProgressPercentage%</p>
                    </div>
                </div>
            </div>

            <div class="mt-6 h-2 overflow-hidden rounded-full bg-white/20">
                <div class="h-2 rounded-full bg-white" style="width: @deck.ProgressPercentage%;"></div>
            </div>
        </section>

        <section class="mt-8 rounded-[2rem] bg-white p-5 shadow-sm ring-1 ring-slate-200">
            <form method="get" asp-action="Vocab_detail" class="grid gap-4 lg:grid-cols-[1.4fr_0.9fr_0.9fr_auto]">
                <input type="hidden" name="deckId" value="@deck.Id" />

                <input type="text"
                       name="search"
                       value="@searchValue"
                       placeholder="Tìm từ, nghĩa, ví dụ..."
                       class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">

                <select name="status" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(selectedStatus) ? "selected" : null)">Tất cả trạng thái</option>
                    <option value="new" selected="@(selectedStatus == "new" ? "selected" : null)">Chưa học</option>
                    <option value="learning" selected="@(selectedStatus == "learning" ? "selected" : null)">Đang học</option>
                    <option value="reviewing" selected="@(selectedStatus == "reviewing" ? "selected" : null)">Cần ôn</option>
                    <option value="mastered" selected="@(selectedStatus == "mastered" ? "selected" : null)">Thành thạo</option>
                </select>

                <select name="sort" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                    <option value="newest" selected="@(selectedSort == "newest" ? "selected" : null)">Mới nhất</option>
                    <option value="oldest" selected="@(selectedSort == "oldest" ? "selected" : null)">Cũ nhất</option>
                    <option value="az" selected="@(selectedSort == "az" ? "selected" : null)">A → Z</option>
                    <option value="za" selected="@(selectedSort == "za" ? "selected" : null)">Z → A</option>
                    <option value="due" selected="@(selectedSort == "due" ? "selected" : null)">Cần ôn trước</option>
                </select>

                <div class="flex gap-3">
                    <button type="submit" class="rounded-2xl bg-indigo-600 px-5 py-3 font-semibold text-white hover:bg-indigo-700">Lọc</button>
                    <a asp-action="Vocab_detail" asp-route-deckId="@deck.Id" class="rounded-2xl border border-slate-200 px-5 py-3 font-semibold text-slate-600 hover:bg-slate-50">Xóa lọc</a>
                </div>
            </form>
        </section>

        <section class="mt-6">
            <div class="mb-4 flex items-center justify-between gap-4">
                <div>
                    <h2 class="text-2xl font-bold text-slate-900">Từ trong bộ</h2>
                    <p class="mt-1 text-sm text-slate-500">Thêm, sửa, xóa từng từ trực tiếp trong bộ này.</p>
                </div>
                <div class="flex items-center gap-2">
                    <a asp-controller="Home"
                           asp-action="Learning"
                           asp-route-deckId="@deck.Id"
                           class="rounded-2xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-50">
                        Học ngay
                    </a>
                </div>
            </div>

            @if (items.Any())
            {
                <div class="grid gap-4 xl:grid-cols-2">
                    @foreach (var item in items)
                    {
                        var vocabData = new
                        {
                            id = item.Id,
                            word = item.Word,
                            pronunciation = item.Pronunciation ?? string.Empty,
                            partOfSpeech = item.PartOfSpeech,
                            meaningVi = item.MeaningVi ?? string.Empty,
                            descriptionEn = item.DescriptionEn ?? string.Empty,
                            exampleSentence = item.ExampleSentence ?? string.Empty,
                            collocations = item.Collocations ?? string.Empty,
                            relatedWords = item.RelatedWords ?? string.Empty,
                            note = item.Note ?? string.Empty,
                            imageUrl = item.ImageUrl ?? string.Empty,
                            audioUrl = item.AudioUrl ?? string.Empty
                        };

                        <article class="rounded-[2rem] bg-white p-5 shadow-sm ring-1 ring-slate-200">
                            <div class="flex items-start justify-between gap-3">
                                <div>
                                    <div class="flex flex-wrap items-center gap-2">
                                        <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-700">@item.Status</span>
                                        @if (item.IsDue)
                                        {
                                            <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">Cần ôn</span>
                                        }
                                    </div>
                                    <h3 class="mt-3 text-xl font-bold text-slate-900">@item.Word</h3>
                                    <p class="mt-1 text-sm text-slate-500">
                                        @if (!string.IsNullOrWhiteSpace(item.Pronunciation))
                                        {
                                            <span>@item.Pronunciation</span>
                                        }
                                        else
                                        {
                                            <span>Chưa có phiên âm</span>
                                        }
                                        @if (item.PartOfSpeech.HasValue)
                                        {
                                            <span class="ml-2 rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-600">POS: @item.PartOfSpeech</span>
                                        }
                                    </p>
                                </div>

                                <div class="text-right text-sm text-slate-500">
                                    <p>@item.CreatedAt.ToString("dd/MM/yyyy")</p>
                                    @if (item.NextReviewDate.HasValue)
                                    {
                                        <p class="mt-1">Ôn lại: @item.NextReviewDate.Value.ToString("dd/MM/yyyy")</p>
                                    }
                                </div>
                            </div>

                            <div class="mt-4 space-y-3 text-sm text-slate-700">
                                @if (!string.IsNullOrWhiteSpace(item.MeaningVi))
                                {
                                    <p><span class="font-semibold text-slate-900">Nghĩa:</span> @item.MeaningVi</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.DescriptionEn))
                                {
                                    <p><span class="font-semibold text-slate-900">Giải thích:</span> @item.DescriptionEn</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.ExampleSentence))
                                {
                                    <p><span class="font-semibold text-slate-900">Ví dụ:</span> @item.ExampleSentence</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.Collocations))
                                {
                                    <p><span class="font-semibold text-slate-900">Collocations:</span> @item.Collocations</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.RelatedWords))
                                {
                                    <p><span class="font-semibold text-slate-900">Related words:</span> @item.RelatedWords</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.Note))
                                {
                                    <p><span class="font-semibold text-slate-900">Ghi chú:</span> @item.Note</p>
                                }
                            </div>

                            <div class="mt-5 flex flex-wrap gap-2">
                                <button type="button"
                                        onclick='openVocabularyModal(@Html.Raw(JsonSerializer.Serialize(vocabData)))'
                                        class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-50">
                                    Sửa từ
                                </button>
                                <button type="button"
                                        onclick="deleteVocabulary(@item.Id)"
                                        class="rounded-xl border border-rose-200 px-4 py-2 text-sm font-semibold text-rose-700 hover:bg-rose-50">
                                    Xóa
                                </button>
                            </div>
                        </article>
                    }
                </div>

                <div class="mt-6 flex items-center justify-between gap-3 rounded-[2rem] bg-white p-4 shadow-sm ring-1 ring-slate-200">
                    <div class="text-sm text-slate-500">
                        Trang @deck.Pagination.Page / @deck.Pagination.TotalPages • @deck.Pagination.TotalItems từ
                    </div>

                    <div class="flex items-center gap-2">
                        @if (deck.Pagination.HasPreviousPage)
                        {
                            <a asp-action="Vocab_detail"
                                   asp-route-deckId="@deck.Id"
                                   asp-route-search="@Model.Search"
                                   asp-route-status="@Model.Status"
                                   asp-route-sort="@Model.Sort"
                                   asp-route-pageNumber="@(deck.Pagination.Page - 1)"
                                   class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-50">
                                Trước
                            </a>
                        }

                        @if (deck.Pagination.HasNextPage)
                        {
                            <a asp-action="Vocab_detail"
                                   asp-route-deckId="@deck.Id"
                                   asp-route-search="@Model.Search"
                                   asp-route-status="@Model.Status"
                                   asp-route-sort="@Model.Sort"
                                   asp-route-pageNumber="@(deck.Pagination.Page + 1)"
                                   class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-50">
                                Sau
                            </a>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="rounded-[2rem] border border-dashed border-slate-300 bg-white p-10 text-center text-slate-500 shadow-sm">
                    Chưa có từ nào trong bộ này. Hãy thêm từ đầu tiên để bắt đầu.
                    <div class="mt-5">
                        <button type="button"
                                onclick="openVocabularyModal()"
                                class="rounded-2xl bg-indigo-600 px-5 py-3 text-sm font-semibold text-white hover:bg-indigo-700">
                            + Thêm từ mới
                        </button>
                    </div>
                </div>
            }
        </section>
    </main>

    <div id="deck-modal" class="fixed inset-0 z-50 hidden items-start justify-center bg-black/50 px-4 py-6">
        <div class="w-full max-w-2xl max-h-[90vh] overflow-hidden rounded-[2rem] bg-white shadow-2xl">
            <div class="flex items-start justify-between gap-4 border-b border-slate-100 px-6 py-5">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-wide text-indigo-600">Deck form</p>
                    <h3 id="deck-modal-title" class="mt-1 text-2xl font-bold">Chỉnh sửa bộ từ</h3>
                </div>
                <button type="button" onclick="closeDeckModal()" class="rounded-full bg-slate-100 px-3 py-1 text-slate-600 hover:bg-slate-200">×</button>
            </div>

            <form id="deck-form" class="max-h-[calc(90vh-88px)] overflow-y-auto px-6 py-5 grid gap-4">
                <input type="hidden" id="deck-id">

                <div>
                    <label class="mb-2 block text-sm font-medium text-slate-700">Tên bộ từ</label>
                    <input type="text" id="deck-title-input" required
                           class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                </div>

                <div>
                    <label class="mb-2 block text-sm font-medium text-slate-700">Mô tả</label>
                    <textarea id="deck-description-input" rows="4"
                              class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200"></textarea>
                </div>

                <div class="grid gap-4 sm:grid-cols-2">
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Tags</label>
                        <input type="text" id="deck-tags-input"
                               class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                    </div>

                    <label class="flex items-center gap-2 self-end rounded-2xl bg-slate-50 px-4 py-3 text-sm text-slate-700">
                        <input type="checkbox" id="deck-public-input" class="rounded border-slate-300 text-indigo-600 focus:ring-indigo-500">
                        Public deck
                    </label>
                </div>

                <div class="flex flex-wrap justify-end gap-3 pt-2">
                    <button type="button"
                            onclick="closeDeckModal()"
                            class="rounded-2xl border border-slate-200 px-5 py-3 font-semibold text-slate-600 hover:bg-slate-50">
                        Hủy
                    </button>
                    <button type="submit" class="rounded-2xl bg-indigo-600 px-5 py-3 font-semibold text-white hover:bg-indigo-700">
                        Lưu
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div id="vocabulary-modal" class="fixed inset-0 z-50 hidden items-start justify-center bg-black/50 px-4 py-6">
        <div class="w-full max-w-3xl max-h-[90vh] overflow-hidden rounded-[2rem] bg-white shadow-2xl">
            <div class="flex items-start justify-between gap-4 border-b border-slate-100 px-6 py-5">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-wide text-indigo-600">Vocabulary form</p>
                    <h3 id="vocabulary-modal-title" class="mt-1 text-2xl font-bold">Thêm từ mới</h3>
                </div>
                <button type="button" onclick="closeVocabularyModal()" class="rounded-full bg-slate-100 px-3 py-1 text-slate-600 hover:bg-slate-200">×</button>
            </div>

            <form id="vocabulary-form" class="max-h-[calc(90vh-88px)] overflow-y-auto px-6 py-5 grid gap-4">
                <input type="hidden" id="vocabulary-id">

                <div class="grid gap-4 md:grid-cols-2">
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Word</label>
                        <input type="text" id="vocabulary-word-input" maxlength="50" required
                               class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                    </div>
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Pronunciation</label>
                        <input type="text" id="vocabulary-pronunciation-input" maxlength="50"
                               class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                    </div>
                </div>

                <div class="grid gap-4 md:grid-cols-2">
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Part of speech</label>
                        <input type="number" id="vocabulary-pos-input"
                               class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200"
                               placeholder="Ví dụ: 1, 2, 3...">
                    </div>
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Meaning (VI)</label>
                        <input type="text" id="vocabulary-meaning-input" maxlength="255"
                               class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                    </div>
                </div>

                <div>
                    <label class="mb-2 block text-sm font-medium text-slate-700">Description (EN)</label>
                    <input type="text" id="vocabulary-description-input" maxlength="255"
                           class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                </div>

                <div>
                    <label class="mb-2 block text-sm font-medium text-slate-700">Example sentence</label>
                    <textarea id="vocabulary-example-input" rows="3" maxlength="255"
                              class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200"></textarea>
                </div>

                <div class="grid gap-4 md:grid-cols-2">
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Collocations</label>
                        <input type="text" id="vocabulary-collocations-input" maxlength="100"
                               class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                    </div>
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Related words</label>
                        <input type="text" id="vocabulary-related-input" maxlength="255"
                               class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                    </div>
                </div>

                <div class="grid gap-4 md:grid-cols-2">
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Image URL</label>
                        <input type="text" id="vocabulary-image-input" maxlength="255"
                               class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                    </div>
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Audio URL</label>
                        <input type="text" id="vocabulary-audio-input" maxlength="255"
                               class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                    </div>
                </div>

                <div>
                    <label class="mb-2 block text-sm font-medium text-slate-700">Note</label>
                    <textarea id="vocabulary-note-input" rows="3" maxlength="255"
                              class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200"></textarea>
                </div>

                <div class="flex flex-wrap justify-end gap-3 pt-2">
                    <button type="button" onclick="closeVocabularyModal()" class="rounded-2xl border border-slate-200 px-5 py-3 font-semibold text-slate-600 hover:bg-slate-50">
                        Hủy
                    </button>
                    <button type="submit" class="rounded-2xl bg-indigo-600 px-5 py-3 font-semibold text-white hover:bg-indigo-700">
                        Lưu từ
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const deckModal = document.getElementById('deck-modal');
        const vocabularyModal = document.getElementById('vocabulary-modal');

        const deckForm = document.getElementById('deck-form');
        const deckIdInput = document.getElementById('deck-id');
        const deckTitleInput = document.getElementById('deck-title-input');
        const deckDescriptionInput = document.getElementById('deck-description-input');
        const deckTagsInput = document.getElementById('deck-tags-input');
        const deckPublicInput = document.getElementById('deck-public-input');
        const deckModalTitle = document.getElementById('deck-modal-title');

        const vocabularyForm = document.getElementById('vocabulary-form');
        const vocabularyIdInput = document.getElementById('vocabulary-id');
        const vocabularyWordInput = document.getElementById('vocabulary-word-input');
        const vocabularyPronunciationInput = document.getElementById('vocabulary-pronunciation-input');
        const vocabularyPosInput = document.getElementById('vocabulary-pos-input');
        const vocabularyMeaningInput = document.getElementById('vocabulary-meaning-input');
        const vocabularyDescriptionInput = document.getElementById('vocabulary-description-input');
        const vocabularyExampleInput = document.getElementById('vocabulary-example-input');
        const vocabularyCollocationsInput = document.getElementById('vocabulary-collocations-input');
        const vocabularyRelatedInput = document.getElementById('vocabulary-related-input');
        const vocabularyNoteInput = document.getElementById('vocabulary-note-input');
        const vocabularyImageInput = document.getElementById('vocabulary-image-input');
        const vocabularyAudioInput = document.getElementById('vocabulary-audio-input');
        const vocabularyModalTitle = document.getElementById('vocabulary-modal-title');

        function openDeckModal(deck) {
        if (deck && deck.id) {
        deckModalTitle.textContent = 'Chỉnh sửa bộ từ';
        deckIdInput.value = deck.id;
        deckTitleInput.value = deck.title || '';
        deckDescriptionInput.value = deck.description || '';
        deckTagsInput.value = deck.tags || '';
        deckPublicInput.checked = !!deck.isPublic;
        } else {
        deckModalTitle.textContent = 'Chỉnh sửa bộ từ';
        deckIdInput.value = '@deck.Id';
        deckTitleInput.value = '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(deck.Title))';
        deckDescriptionInput.value = '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(deck.Description ?? string.Empty))';
        deckTagsInput.value = '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(deck.Tags ?? string.Empty))';
        deckPublicInput.checked = @(deck.IsPublic ? "true" : "false");
        }

        deckModal.classList.remove('hidden');
        deckModal.classList.add('flex');
        setTimeout(() => deckTitleInput.focus(), 0);
        }

        function closeDeckModal() {
        deckModal.classList.add('hidden');
        deckModal.classList.remove('flex');
        }

        function openVocabularyModal(vocab) {
        if (vocab && vocab.id) {
        vocabularyModalTitle.textContent = 'Chỉnh sửa từ';
        vocabularyIdInput.value = vocab.id;
        vocabularyWordInput.value = vocab.word || '';
        vocabularyPronunciationInput.value = vocab.pronunciation || '';
        vocabularyPosInput.value = vocab.partOfSpeech ?? '';
        vocabularyMeaningInput.value = vocab.meaningVi || '';
        vocabularyDescriptionInput.value = vocab.descriptionEn || '';
        vocabularyExampleInput.value = vocab.exampleSentence || '';
        vocabularyCollocationsInput.value = vocab.collocations || '';
        vocabularyRelatedInput.value = vocab.relatedWords || '';
        vocabularyNoteInput.value = vocab.note || '';
        vocabularyImageInput.value = vocab.imageUrl || '';
        vocabularyAudioInput.value = vocab.audioUrl || '';
        } else {
        vocabularyModalTitle.textContent = 'Thêm từ mới';
        vocabularyIdInput.value = '';
        vocabularyWordInput.value = '';
        vocabularyPronunciationInput.value = '';
        vocabularyPosInput.value = '';
        vocabularyMeaningInput.value = '';
        vocabularyDescriptionInput.value = '';
        vocabularyExampleInput.value = '';
        vocabularyCollocationsInput.value = '';
        vocabularyRelatedInput.value = '';
        vocabularyNoteInput.value = '';
        vocabularyImageInput.value = '';
        vocabularyAudioInput.value = '';
        }

        vocabularyModal.classList.remove('hidden');
        vocabularyModal.classList.add('flex');
        setTimeout(() => vocabularyWordInput.focus(), 0);
        }

        function closeVocabularyModal() {
        vocabularyModal.classList.add('hidden');
        vocabularyModal.classList.remove('flex');
        }

        async function deleteDeck(deckId) {
        if (!confirm('Bạn chắc chắn muốn xóa bộ từ này?')) {
        return;
        }

        const response = await fetch(`/api/decks/${deckId}`, {
        method: 'DELETE'
        });

        const payload = await response.json().catch(() => null);

        if (!response.ok) {
        alert(payload?.message || 'Không thể xóa bộ từ.');
        return;
        }

        window.location.href = '@Url.Action("Vocabulary", "Home")';
        }

        async function deleteVocabulary(vocabularyId) {
        if (!confirm('Bạn chắc chắn muốn xóa từ này?')) {
        return;
        }

        const response = await fetch(`/api/decks/vocabularies/${vocabularyId}`, {
        method: 'DELETE'
        });

        const payload = await response.json().catch(() => null);

        if (!response.ok) {
        alert(payload?.message || 'Không thể xóa từ vựng.');
        return;
        }

        location.reload();
        }

        deckForm.addEventListener('submit', async function (event) {
        event.preventDefault();

        const deckId = deckIdInput.value.trim();
        const body = {
        title: deckTitleInput.value.trim(),
        description: deckDescriptionInput.value.trim() || null,
        tags: deckTagsInput.value.trim() || null,
        isPublic: deckPublicInput.checked
        };

        if (!body.title) {
        alert('Tên bộ từ là bắt buộc.');
        deckTitleInput.focus();
        return;
        }

        const response = await fetch(`/api/decks/${deckId}`, {
        method: 'PUT',
        headers: {
        'Content-Type': 'application/json'
        },
        body: JSON.stringify(body)
        });

        const payload = await response.json().catch(() => null);

        if (!response.ok) {
        alert(payload?.message || 'Không thể cập nhật bộ từ.');
        return;
        }

        closeDeckModal();
        location.reload();
        });

        vocabularyForm.addEventListener('submit', async function (event) {
        event.preventDefault();

        const vocabularyId = vocabularyIdInput.value.trim();
        const body = {
        word: vocabularyWordInput.value.trim(),
        pronunciation: vocabularyPronunciationInput.value.trim() || null,
        partOfSpeech: vocabularyPosInput.value.trim() ? Number(vocabularyPosInput.value.trim()) : null,
        meaningVi: vocabularyMeaningInput.value.trim() || null,
        descriptionEn: vocabularyDescriptionInput.value.trim() || null,
        exampleSentence: vocabularyExampleInput.value.trim() || null,
        collocations: vocabularyCollocationsInput.value.trim() || null,
        relatedWords: vocabularyRelatedInput.value.trim() || null,
        note: vocabularyNoteInput.value.trim() || null,
        imageUrl: vocabularyImageInput.value.trim() || null,
        audioUrl: vocabularyAudioInput.value.trim() || null
        };

        if (!body.word) {
        alert('Từ vựng là bắt buộc.');
        vocabularyWordInput.focus();
        return;
        }

        const url = vocabularyId
        ? `/api/decks/vocabularies/${vocabularyId}`
        : `/api/decks/${@deck.Id}/vocabularies`;

        const method = vocabularyId ? 'PUT' : 'POST';

        const response = await fetch(url, {
        method: method,
        headers: {
        'Content-Type': 'application/json'
        },
        body: JSON.stringify(body)
        });

        const payload = await response.json().catch(() => null);

        if (!response.ok) {
        alert(payload?.message || 'Không thể cập nhật từ vựng.');
        return;
        }

        closeVocabularyModal();
        location.reload();
        });

        function createVocabularyForThisDeck() {
        openVocabularyModal();
        }
    </script>
</body>
</html>