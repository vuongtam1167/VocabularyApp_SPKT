@model Vocab_LearningApp.Models.ViewModels.DeckDetailPageViewModel
@{
    Layout = null;
    ViewData["Title"] = "Vocab Detail Page";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.Deck.Title - VocabMaster</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }
    </style>
</head>
<body class="bg-gray-50">
    <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="container mx-auto px-4">
            <div class="flex items-center justify-between h-16">
                <div class="flex items-center gap-4">
                    <a asp-controller="Home" asp-action="Vocabulary" class="text-gray-600 hover:text-gray-900">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                        </svg>
                    </a>
                    <div class="flex items-center gap-2">
                        <span class="text-2xl">📚</span>
                        <span class="text-xl font-bold text-gray-900">VocabMaster</span>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <img src="@(Model.User.AvatarUrl ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(Model.User.FullName)}&background=4f46e5&color=fff")" alt="Avatar" class="w-10 h-10 rounded-full">
                </div>
            </div>
        </div>
    </header>

    <main class="container mx-auto px-4 py-8">
        <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl p-8 mb-8 text-white">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
                <div class="flex-1">
                    <div class="flex items-center gap-3 mb-4">
                        <span class="bg-white/20 text-white text-sm font-semibold px-4 py-1 rounded-full">
                            @(Model.Deck.Tags ?? "General")
                        </span>
                        <span class="text-white/80 text-sm">Tạo ngày @Model.Deck.CreatedAt.ToString("dd/MM/yyyy")</span>
                    </div>
                    <h1 class="text-4xl font-bold mb-3">@Model.Deck.Title</h1>
                    <p class="text-blue-100 mb-4">@(Model.Deck.Description ?? "Bộ từ chưa có mô tả.")</p>

                    <div class="flex flex-wrap gap-4 text-sm">
                        <div class="bg-white/20 px-4 py-2 rounded-lg">
                            <span class="text-white/80">Tổng số từ: </span>
                            <span class="font-bold">@Model.Deck.TotalWords</span>
                        </div>
                        <div class="bg-white/20 px-4 py-2 rounded-lg">
                            <span class="text-white/80">Đã học: </span>
                            <span class="font-bold">@Model.Deck.LearnedWords</span>
                        </div>
                        <div class="bg-white/20 px-4 py-2 rounded-lg">
                            <span class="text-white/80">Cần ôn: </span>
                            <span class="font-bold">@Model.Deck.DueWords</span>
                        </div>
                    </div>
                </div>
                <div class="flex flex-col gap-3">
                    <a asp-controller="Home" asp-action="Learning" asp-route-deckId="@Model.Deck.Id" class="bg-white text-blue-600 px-6 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors text-center">
                        🎯 Học ngay
                    </a>
                    <button type="button" class="bg-white/20 text-white px-6 py-3 rounded-lg font-semibold hover:bg-white/30 transition-colors">
                        ✏️ Chỉnh sửa qua API
                    </button>
                    <button type="button" class="bg-white/20 text-white px-6 py-3 rounded-lg font-semibold hover:bg-white/30 transition-colors">
                        ➕ Thêm từ qua API
                    </button>
                </div>
            </div>

            <div class="mt-6">
                <div class="flex justify-between text-sm mb-2">
                    <span>Tiến độ học tập</span>
                    <span class="font-bold">@Model.Deck.ProgressPercentage%</span>
                </div>
                <div class="w-full bg-white/20 rounded-full h-3">
                    <div class="bg-white h-3 rounded-full" style="width: @Model.Deck.ProgressPercentage%;"></div>
                </div>
            </div>
        </div>

        <form method="get" asp-action="Vocab_detail" class="bg-white rounded-xl shadow-sm p-4 mb-6 border border-gray-100">
            <input type="hidden" name="deckId" value="@Model.Deck.Id" />
            <div class="flex flex-col md:flex-row gap-4">
                <div class="flex-1">
                    <input type="text"
                           name="search"
                           value="@Model.Search"
                           placeholder="Tìm kiếm từ vựng..."
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none">
                </div>
                <select name="status" class="px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none">
                    @if (string.IsNullOrWhiteSpace(Model.Status))
                    {
                        <option value="" selected>Tất cả</option>
                    }
                    else
                    {
                        <option value="">Tất cả</option>
                    }
                    @if (Model.Status == "new") { <option value="new" selected>Chưa học</option> } else { <option value="new">Chưa học</option> }
                    @if (Model.Status == "learning") { <option value="learning" selected>Đang học</option> } else { <option value="learning">Đang học</option> }
                    @if (Model.Status == "mastered") { <option value="mastered" selected>Thành thạo</option> } else { <option value="mastered">Thành thạo</option> }
                    @if (Model.Status == "reviewing") { <option value="reviewing" selected>Cần ôn</option> } else { <option value="reviewing">Cần ôn</option> }
                </select>
                <select name="sort" class="px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none">
                    @if (string.IsNullOrWhiteSpace(Model.Sort) || Model.Sort == "az") { <option value="az" selected>A-Z</option> } else { <option value="az">A-Z</option> }
                    @if (Model.Sort == "za") { <option value="za" selected>Z-A</option> } else { <option value="za">Z-A</option> }
                    @if (Model.Sort == "newest") { <option value="newest" selected>Mới nhất</option> } else { <option value="newest">Mới nhất</option> }
                    @if (Model.Sort == "oldest") { <option value="oldest" selected>Cũ nhất</option> } else { <option value="oldest">Cũ nhất</option> }
                </select>
                <button type="submit" class="px-5 py-2 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700">Lọc</button>
            </div>
        </form>

        <div class="space-y-4">
            @if (Model.Deck.VocabularyItems.Any())
            {
                @foreach (var item in Model.Deck.VocabularyItems)
                {
                    var statusKey = item.Status?.ToLowerInvariant() ?? "new";
                    var badgeClass = statusKey switch
                    {
                        "mastered" => "bg-green-100 text-green-700",
                        "learning" => "bg-orange-100 text-orange-700",
                        "reviewing" => "bg-yellow-100 text-yellow-700",
                        _ => "bg-blue-100 text-blue-700"
                    };
                    var statusLabel = statusKey switch
                    {
                        "mastered" => "Thành thạo",
                        "learning" => "Đang học",
                        "reviewing" => item.IsDue ? "Cần ôn" : "Đang ôn",
                        _ => "Chưa học"
                    };

                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-all">
                        <div class="p-6">
                            <div class="flex items-start justify-between mb-4 gap-4">
                                <div class="flex-1">
                                    <div class="flex items-center gap-3 mb-2 flex-wrap">
                                        <h3 class="text-2xl font-bold text-gray-900">@item.Word</h3>
                                        <span class="text-gray-500 text-sm">@item.Pronunciation</span>
                                        @if (!string.IsNullOrWhiteSpace(item.AudioUrl))
                                        {
                                            <a href="@item.AudioUrl" target="_blank" class="text-blue-600 hover:text-blue-700">Audio</a>
                                        }
                                    </div>
                                    <p class="text-gray-600 mb-3"><strong>Nghĩa:</strong> @(item.MeaningVi ?? "Chưa cập nhật")</p>
                                    <p class="text-gray-600 mb-3"><strong>Mô tả:</strong> @(item.DescriptionEn ?? "Chưa cập nhật")</p>
                                    <p class="text-gray-600 mb-3"><strong>Ví dụ:</strong> <em>@(item.ExampleSentence ?? "Chưa có ví dụ")</em></p>
                                    <p class="text-gray-600 mb-3"><strong>Collocation:</strong> @(item.Collocations ?? "Chưa cập nhật")</p>
                                    <p class="text-gray-600 mb-3"><strong>Từ liên quan:</strong> @(item.RelatedWords ?? "Chưa cập nhật")</p>
                                    <p class="text-gray-500 text-sm">SRS: EF @item.EaseFactor.ToString("0.00") • Lặp @item.Repetitions • Lịch ôn @(item.NextReviewDate?.ToString("dd/MM/yyyy") ?? "chưa có")</p>
                                </div>
                                <div class="flex flex-col gap-2 items-end">
                                    <span class="@badgeClass text-xs font-semibold px-3 py-1 rounded-full text-center min-w-[96px]">
                                        @statusLabel
                                    </span>
                                    @if (item.IsDue)
                                    {
                                        <span class="text-xs text-orange-600">Đến hạn ôn</span>
                                    }
                                </div>
                            </div>
                            <div class="flex items-center gap-2 flex-wrap">
                                <a asp-controller="Home" asp-action="Learning" asp-route-deckId="@Model.Deck.Id" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm">
                                    @(item.Status == "new" ? "Học ngay" : "Học lại")
                                </a>
                                <button type="button" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors text-sm">
                                    Chỉnh sửa qua API
                                </button>
                                <button type="button" class="px-4 py-2 bg-red-50 text-red-700 rounded-lg hover:bg-red-100 transition-colors text-sm">
                                    Xóa qua API
                                </button>
                            </div>
                        </div>
                    </div>
                }

                @if (Model.Deck.Pagination.TotalPages > 1)
                {
                    <div class="flex items-center justify-center gap-2 py-6 flex-wrap">
                        <a asp-action="Vocab_detail" asp-route-deckId="@Model.Deck.Id" asp-route-search="@Model.Search" asp-route-status="@Model.Status" asp-route-sort="@Model.Sort" asp-route-pageNumber="@(Model.Deck.Pagination.Page - 1)" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 @(Model.Deck.Pagination.HasPreviousPage ? string.Empty : "pointer-events-none opacity-50")">Trước</a>
                        @for (var pageNumber = 1; pageNumber <= Model.Deck.Pagination.TotalPages; pageNumber++)
                        {
                            <a asp-action="Vocab_detail" asp-route-deckId="@Model.Deck.Id" asp-route-search="@Model.Search" asp-route-status="@Model.Status" asp-route-sort="@Model.Sort" asp-route-pageNumber="@pageNumber" class="px-4 py-2 rounded-lg @(pageNumber == Model.Deck.Pagination.Page ? "bg-blue-600 text-white" : "border border-gray-300 hover:bg-gray-50")">@pageNumber</a>
                        }
                        <a asp-action="Vocab_detail" asp-route-deckId="@Model.Deck.Id" asp-route-search="@Model.Search" asp-route-status="@Model.Status" asp-route-sort="@Model.Sort" asp-route-pageNumber="@(Model.Deck.Pagination.Page + 1)" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 @(Model.Deck.Pagination.HasNextPage ? string.Empty : "pointer-events-none opacity-50")">Sau</a>
                    </div>
                }
            }
            else
            {
                <div class="bg-white rounded-xl border border-dashed border-gray-300 p-10 text-center text-gray-500">
                    Không có từ nào khớp bộ lọc hiện tại.
                </div>
            }
        </div>
    </main>
</body>
</html>
