@model Vocab_LearningApp.Models.ViewModels.LoginPageViewModel

@{
    ViewData["Title"] = "Login Page";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - VocabMaster</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }

        .tab-button.active {
        background: white;
        color: #4f46e5;
        font-weight: 600;
        }
    </style>
</head>
<body class="bg-gradient-to-br from-indigo-500 via-purple-500 to-pink-500 min-h-screen flex items-center justify-center p-4">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <h1 class="text-5xl font-bold text-white mb-2">📚 VocabMaster</h1>
            <p class="text-white/80">Nâng cao vốn từ vựng tiếng Anh của bạn</p>
        </div>

        <div class="bg-white rounded-2xl shadow-2xl overflow-hidden">
            <div class="flex bg-gray-100 p-1">
                <button type="button"
                        class="tab-button flex-1 py-3 rounded-lg transition-all @(Model.ActiveTab == "login" ? "active" : "text-gray-600")"
                        onclick="showTab('login')">
                    Đăng nhập
                </button>
                <button type="button"
                        class="tab-button flex-1 py-3 rounded-lg transition-all @(Model.ActiveTab == "register" ? "active" : "text-gray-600")"
                        onclick="showTab('register')">
                    Đăng ký
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="mx-6 mt-6 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700">
                    @Model.ErrorMessage
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
            {
                <div class="mx-6 mt-6 rounded-lg bg-green-50 px-4 py-3 text-sm text-green-700">
                    @Model.SuccessMessage
                </div>
            }

            <div id="login-tab" class="p-8 @(Model.ActiveTab == "register" ? "hidden" : string.Empty)">
                <h2 class="text-2xl font-bold text-gray-900 mb-6">Chào mừng trở lại!</h2>

                <form asp-action="Login" method="post" class="space-y-4">
                    @Html.AntiForgeryToken()

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Email</label>
                        <input type="email"
                               name="Email"
                               value="@Model.Login.Email"
                               placeholder="your@email.com"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Mật khẩu</label>
                        <input type="password"
                               name="Password"
                               placeholder="••••••••"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none">
                    </div>

                    <div class="flex items-center justify-between">
                        <label class="flex items-center">
                            <input type="checkbox"
                                   name="RememberMe"
                                   value="true"
                            @(Model.Login.RememberMe ? "checked" : null)
                                   class="rounded text-indigo-600 focus:ring-indigo-500">
                            <span class="ml-2 text-sm text-gray-600">Ghi nhớ đăng nhập</span>
                        </label>
                        <span class="text-sm text-gray-400">JWT + cookie an toàn</span>
                    </div>

                    <button type="submit" class="w-full bg-indigo-600 text-white py-3 rounded-lg font-semibold hover:bg-indigo-700 transition-colors">
                        Đăng nhập
                    </button>
                </form>

                <div class="mt-4 rounded-lg bg-indigo-50 px-4 py-3 text-sm text-indigo-700">
                    Google login đã có API tại <code>/api/auth/google</code>. Chỉ cần nối thêm Google OAuth credentials là dùng được ngay.
                </div>
            </div>

            <div id="register-tab" class="p-8 @(Model.ActiveTab == "register" ? string.Empty : "hidden")">
                <h2 class="text-2xl font-bold text-gray-900 mb-6">Tạo tài khoản mới</h2>

                <form asp-action="Register" method="post" class="space-y-4">
                    @Html.AntiForgeryToken()

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Họ và tên</label>
                        <input type="text"
                               name="FullName"
                               value="@Model.Register.FullName"
                               placeholder="Nguyễn Văn A"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Email</label>
                        <input type="email"
                               name="Email"
                               value="@Model.Register.Email"
                               placeholder="your@email.com"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Mật khẩu</label>
                        <input type="password"
                               name="Password"
                               placeholder="••••••••"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Mục tiêu học (Tùy chọn)</label>
                        <select name="LearningGoal"
                                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none">
                            @if (string.IsNullOrWhiteSpace(Model.Register.LearningGoal))
                            {
                                <option value="" selected>Chọn mục tiêu</option>
                            }
                            else
                            {
                                <option value="">Chọn mục tiêu</option>
                            }

                            @if (Model.Register.LearningGoal == "IELTS")
                            {
                                <option value="IELTS" selected>IELTS</option>
                            }
                            else
                            {
                                <option value="IELTS">IELTS</option>
                            }

                            @if (Model.Register.LearningGoal == "TOEIC")
                            {
                                <option value="TOEIC" selected>TOEIC</option>
                            }
                            else
                            {
                                <option value="TOEIC">TOEIC</option>
                            }

                            @if (Model.Register.LearningGoal == "TOEFL")
                            {
                                <option value="TOEFL" selected>TOEFL</option>
                            }
                            else
                            {
                                <option value="TOEFL">TOEFL</option>
                            }

                            @if (Model.Register.LearningGoal == "Business")
                            {
                                <option value="Business" selected>Business English</option>
                            }
                            else
                            {
                                <option value="Business">Business English</option>
                            }

                            @if (Model.Register.LearningGoal == "Travel")
                            {
                                <option value="Travel" selected>Travel English</option>
                            }
                            else
                            {
                                <option value="Travel">Travel English</option>
                            }

                            @if (Model.Register.LearningGoal == "General")
                            {
                                <option value="General" selected>General English</option>
                            }
                            else
                            {
                                <option value="General">General English</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Trình độ hiện tại (Tùy chọn)</label>
                        <select name="CurrentLevel"
                                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none">
                            @if (string.IsNullOrWhiteSpace(Model.Register.CurrentLevel))
                            {
                                <option value="" selected>Chọn trình độ</option>
                            }
                            else
                            {
                                <option value="">Chọn trình độ</option>
                            }

                            @if (Model.Register.CurrentLevel == "A1")
                            {
                                <option value="A1" selected>A1 - Beginner</option>
                            }
                            else
                            {
                                <option value="A1">A1 - Beginner</option>
                            }

                            @if (Model.Register.CurrentLevel == "A2")
                            {
                                <option value="A2" selected>A2 - Elementary</option>
                            }
                            else
                            {
                                <option value="A2">A2 - Elementary</option>
                            }

                            @if (Model.Register.CurrentLevel == "B1")
                            {
                                <option value="B1" selected>B1 - Intermediate</option>
                            }
                            else
                            {
                                <option value="B1">B1 - Intermediate</option>
                            }

                            @if (Model.Register.CurrentLevel == "B2")
                            {
                                <option value="B2" selected>B2 - Upper Intermediate</option>
                            }
                            else
                            {
                                <option value="B2">B2 - Upper Intermediate</option>
                            }

                            @if (Model.Register.CurrentLevel == "C1")
                            {
                                <option value="C1" selected>C1 - Advanced</option>
                            }
                            else
                            {
                                <option value="C1">C1 - Advanced</option>
                            }

                            @if (Model.Register.CurrentLevel == "C2")
                            {
                                <option value="C2" selected>C2 - Proficiency</option>
                            }
                            else
                            {
                                <option value="C2">C2 - Proficiency</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Mục tiêu từ mới mỗi ngày</label>
                        <input type="number"
                               name="DailyTarget"
                               min="1"
                               max="200"
                               value="@(Model.Register.DailyTarget ?? 10)"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none">
                    </div>

                    <div class="flex items-start">
                        <input type="checkbox"
                               name="AcceptTerms"
                               value="true"
                        @(Model.Register.AcceptTerms ? "checked" : null)
                               class="mt-1 rounded text-indigo-600 focus:ring-indigo-500">
                        <input type="hidden" name="AcceptTerms" value="false" />
                        <label class="ml-2 text-sm text-gray-600">
                            Tôi đồng ý với <span class="text-indigo-600">Điều khoản dịch vụ</span> và <span class="text-indigo-600">Chính sách bảo mật</span>
                        </label>
                    </div>

                    <button type="submit" class="w-full bg-indigo-600 text-white py-3 rounded-lg font-semibold hover:bg-indigo-700 transition-colors">
                        Đăng ký
                    </button>
                </form>
            </div>
        </div>

        <div class="text-center mt-6 text-white/80 text-sm">
            Server mặc định: <code class="text-white">.\\SQLEXPRESS</code> | User: <code class="text-white">sa</code>
        </div>
    </div>

    <script>
        function showTab(tabName) {
        const loginTab = document.getElementById('login-tab');
        const registerTab = document.getElementById('register-tab');
        const buttons = document.querySelectorAll('.tab-button');

        if (tabName === 'login') {
        loginTab.classList.remove('hidden');
        registerTab.classList.add('hidden');
        buttons[0].classList.add('active');
        buttons[1].classList.remove('active');
        } else {
        loginTab.classList.add('hidden');
        registerTab.classList.remove('hidden');
        buttons[0].classList.remove('active');
        buttons[1].classList.add('active');
        }
        }
    </script>
</body>
</html>