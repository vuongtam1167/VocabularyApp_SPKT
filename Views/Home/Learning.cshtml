@using System.Text.Json
@model Vocab_LearningApp.Models.ViewModels.LearningPageViewModel
@{
    Layout = null;
    ViewData["Title"] = "Học tập";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Học tập - VocabMaster</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; }
        .flashcard { perspective: 1000px; min-height: 420px; }
        .flashcard-inner { position: relative; width: 100%; height: 100%; text-align: center; transition: transform .6s; transform-style: preserve-3d; }
        .flashcard.flipped .flashcard-inner { transform: rotateY(180deg); }
        .flashcard-front, .flashcard-back { position: absolute; width: 100%; height: 100%; backface-visibility: hidden; border-radius: 1.5rem; }
        .flashcard-back { transform: rotateY(180deg); }
    </style>
</head>
<body class="min-h-screen bg-gradient-to-br from-indigo-600 via-purple-600 to-pink-600 text-white">
    <header class="border-b border-white/15 bg-white/10 backdrop-blur">
        <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
            <a asp-controller="Home" asp-action="Vocab_detail" asp-route-deckId="@Model.Session.DeckId" class="flex items-center gap-3 text-white hover:text-white/80">
                <span class="text-2xl">←</span>
                <div>
                    <p class="font-semibold" id="deck-title">@Model.Session.DeckTitle</p>
                    <p class="text-xs text-white/70" id="session-subtitle">@(Model.Session.CurrentCard is null ? "Không còn từ nào" : $"Đang học: 1/{Model.Session.TotalCards}")</p>
                </div>
            </a>
            <div class="text-right text-sm text-white/80">
                <p>@Model.User.FullName</p>
                <p>@Model.User.LearningGoal • @Model.User.CurrentLevel</p>
            </div>
        </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div class="mb-6 grid gap-4 md:grid-cols-4">
            <div class="rounded-2xl bg-white/10 p-4 backdrop-blur">
                <p class="text-sm text-white/70">Tổng thẻ</p>
                <p id="total-cards" class="mt-2 text-3xl font-black">@Model.Session.TotalCards</p>
            </div>
            <div class="rounded-2xl bg-white/10 p-4 backdrop-blur">
                <p class="text-sm text-white/70">Đến hạn ôn</p>
                <p id="due-cards" class="mt-2 text-3xl font-black">@Model.Session.DueCards</p>
            </div>
            <div class="rounded-2xl bg-white/10 p-4 backdrop-blur">
                <p class="text-sm text-white/70">Từ mới</p>
                <p id="new-cards" class="mt-2 text-3xl font-black">@Model.Session.NewCards</p>
            </div>
            <div class="rounded-2xl bg-white/10 p-4 backdrop-blur">
                <p class="text-sm text-white/70">Accuracy</p>
                <p id="accuracy-count" class="mt-2 text-3xl font-black">@Model.Session.AccuracyPercentage%</p>
            </div>
        </div>

        <div class="mb-8">
            <div class="h-2 w-full overflow-hidden rounded-full bg-white/20">
                <div id="progress-bar" class="h-2 rounded-full bg-white transition-all" style="width:@(Model.Session.TotalCards == 0 ? 0 : 100 / Math.Max(Model.Session.TotalCards, 1))%"></div>
            </div>
            <p id="progress-text" class="mt-2 text-center text-sm text-white/80">@(Model.Session.CurrentCard is null ? 0 : 1) / @Model.Session.TotalCards từ</p>
        </div>

        <div class="mx-auto mb-8 max-w-2xl">
            <div class="flashcard" id="flashcard" onclick="flipCard()">
                <div class="flashcard-inner">
                    <div class="flashcard-front bg-white p-8 text-slate-900 shadow-2xl">
                        <div class="flex h-full min-h-[420px] flex-col items-center justify-center" id="flashcard-front"></div>
                    </div>
                    <div class="flashcard-back bg-gradient-to-br from-indigo-700 to-fuchsia-700 p-8 shadow-2xl" id="flashcard-back-container">
                        <div class="flex h-full min-h-[420px] flex-col text-white" id="flashcard-back"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mx-auto max-w-2xl" id="rating-buttons"></div>

        <div class="mx-auto mt-10 max-w-4xl rounded-[2rem] bg-white/10 p-6 backdrop-blur">
            <h3 class="text-center text-lg font-bold">Cách đánh giá SRS</h3>
            <div class="mt-4 grid gap-3 md:grid-cols-4">
                <div class="rounded-2xl bg-white/10 p-4 text-center"><p class="text-2xl">Again</p><p class="text-sm text-white/75">Ôn sớm hơn</p></div>
                <div class="rounded-2xl bg-white/10 p-4 text-center"><p class="text-2xl">Hard</p><p class="text-sm text-white/75">Giữ nhịp ngắn</p></div>
                <div class="rounded-2xl bg-white/10 p-4 text-center"><p class="text-2xl">Good</p><p class="text-sm text-white/75">Theo lịch chuẩn</p></div>
                <div class="rounded-2xl bg-white/10 p-4 text-center"><p class="text-2xl">Easy</p><p class="text-sm text-white/75">Giãn lịch mạnh</p></div>
            </div>
        </div>
    </main>

    <script>
        let isFlipped = false;
        let session = null;

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.innerText = text ?? '';
            return div.innerHTML;
        }

        function getCurrentCard() {
            return session?.CurrentCard || session?.currentCard || null;
        }

        function getQueue() {
            return session?.Queue || session?.queue || [];
        }

        function getReviewPreviews() {
            return session?.ReviewPreviews || session?.reviewPreviews || [];
        }

        function flipCard() {
            if (!getCurrentCard()) return;
            isFlipped = !isFlipped;
            document.getElementById('flashcard').classList.toggle('flipped', isFlipped);
        }

        function buttonClass(label) {
            switch ((label || '').toLowerCase()) {
                case 'quên': return 'bg-red-500 hover:bg-red-600';
                case 'khó': return 'bg-orange-500 hover:bg-orange-600';
                case 'dễ': return 'bg-emerald-500 hover:bg-emerald-600';
                default: return 'bg-indigo-500 hover:bg-indigo-600';
            }
        }

        async function loadSession() {
            const urlParams = new URLSearchParams(window.location.search);
            const deckId = urlParams.get('deckId');
            const response = await fetch(`/api/learning/session?deckId=${deckId ?? ''}`, { credentials: 'same-origin' });
            if (!response.ok) {
                alert('Không thể tải phiên học.');
                return;
            }
            session = await response.json();
            renderSession();
        }

        function renderSession() {
            if (!session) return;

            const currentCard = getCurrentCard();
            const queue = getQueue();
            const totalCards = session.TotalCards ?? session.totalCards ?? queue.length;
            const completedCards = session.CompletedCards ?? session.completedCards ?? 0;
            const correctAnswers = session.CorrectAnswers ?? session.correctAnswers ?? 0;
            const accuracy = session.AccuracyPercentage ?? session.accuracyPercentage ?? 0;
            const front = document.getElementById('flashcard-front');
            const back = document.getElementById('flashcard-back');
            const ratingButtons = document.getElementById('rating-buttons');

            document.getElementById('deck-title').textContent = session.DeckTitle || session.deckTitle || 'Buổi học';
            document.getElementById('total-cards').textContent = totalCards;
            document.getElementById('due-cards').textContent = session.DueCards ?? session.dueCards ?? 0;
            document.getElementById('new-cards').textContent = session.NewCards ?? session.newCards ?? 0;
            document.getElementById('accuracy-count').textContent = `${accuracy}%`;
            document.getElementById('session-subtitle').textContent = currentCard ? `Đang học: ${Math.min(completedCards + 1, totalCards)}/${totalCards}` : 'Đã hoàn thành';
            document.getElementById('progress-text').textContent = totalCards === 0 ? '0 / 0 từ' : `${Math.min(completedCards + 1, totalCards)} / ${totalCards} từ`;
            document.getElementById('progress-bar').style.width = `${totalCards === 0 ? 0 : Math.min(100, Math.round((Math.max(completedCards, 1) / totalCards) * 100))}%`;

            if (!currentCard) {
                front.innerHTML = `
                    <div class="flex h-full min-h-[420px] flex-col items-center justify-center text-center">
                        <h2 class="text-4xl font-black">Hoàn thành phiên học</h2>
                        <p class="mt-3 text-slate-500">Không còn thẻ nào trong hàng đợi hiện tại.</p>
                        <a href="/Home/Vocabulary" class="mt-6 rounded-2xl bg-indigo-600 px-6 py-3 font-semibold text-white hover:bg-indigo-700">Quay lại bộ từ</a>
                    </div>`;
                back.innerHTML = front.innerHTML;
                ratingButtons.innerHTML = '';
                return;
            }

            front.innerHTML = `
                <div class="flex h-full min-h-[420px] flex-col items-center justify-center text-center">
                    <p class="mb-3 rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-700">${escapeHtml(currentCard.DeckTitle || currentCard.deckTitle || '')}</p>
                    <h2 class="text-5xl font-black">${escapeHtml(currentCard.Word || currentCard.word)}</h2>
                    <p class="mt-4 text-xl text-slate-500">${escapeHtml(currentCard.Pronunciation || currentCard.pronunciation || '')}</p>
                    <p class="mt-8 text-sm text-slate-400">Nhấn vào thẻ để xem nghĩa</p>
                </div>`;

            back.innerHTML = `
                <div class="flex h-full min-h-[420px] flex-col justify-between">
                    <div>
                        <h3 class="text-3xl font-black">${escapeHtml(currentCard.Word || currentCard.word)}</h3>
                        <div class="mt-6 space-y-4 text-left text-white">
                            <div><p class="text-white/70 text-sm mb-1">Nghĩa</p><p class="text-lg">${escapeHtml(currentCard.MeaningVi || currentCard.meaningVi || 'Chưa cập nhật')}</p></div>
                            <div><p class="text-white/70 text-sm mb-1">Mô tả</p><p>${escapeHtml(currentCard.DescriptionEn || currentCard.descriptionEn || 'Chưa cập nhật')}</p></div>
                            <div><p class="text-white/70 text-sm mb-1">Ví dụ</p><p class="italic">${escapeHtml(currentCard.ExampleSentence || currentCard.exampleSentence || 'Chưa có ví dụ')}</p></div>
                            <div><p class="text-white/70 text-sm mb-1">Collocation</p><p>${escapeHtml(currentCard.Collocations || currentCard.collocations || 'Chưa cập nhật')}</p></div>
                            <div><p class="text-white/70 text-sm mb-1">Từ liên quan</p><p>${escapeHtml(currentCard.RelatedWords || currentCard.relatedWords || 'Chưa cập nhật')}</p></div>
                        </div>
                    </div>
                    <p class="mt-6 text-center text-sm text-white/70">Nhấn vào thẻ để quay lại</p>
                </div>`;

            ratingButtons.innerHTML = `
                <p class="mb-4 text-center text-white">Bạn nhớ từ này thế nào?</p>
                <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
                    ${getReviewPreviews().map(preview => `
                        <button type="button" onclick="submitReview(${preview.Rating ?? preview.rating})" class="${buttonClass(preview.Label || preview.label)} rounded-2xl px-4 py-4 font-semibold text-white shadow-lg transition">
                            <div class="text-2xl mb-1">${escapeHtml(preview.Emoji || preview.emoji)}</div>
                            <div class="text-sm">${escapeHtml(preview.Label || preview.label)}</div>
                            <div class="text-xs opacity-80">${escapeHtml(preview.ScheduleText || preview.scheduleText || '')}</div>
                        </button>`).join('')}
                </div>`;
        }

        async function submitReview(rating) {
            const currentCard = getCurrentCard();
            if (!currentCard) return;

            const response = await fetch('/api/learning/review', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    vocabularyId: currentCard.VocabularyId || currentCard.vocabularyId,
                    deckId: session.DeckId || session.deckId,
                    rating
                })
            });

            if (!response.ok) {
                alert('Không thể ghi nhận kết quả học.');
                return;
            }

            const result = await response.json();
            session = result.Session || result.session;
            isFlipped = false;
            document.getElementById('flashcard').classList.remove('flipped');
            renderSession();
        }

        document.addEventListener('keydown', function (event) {
            if (event.code === 'Space') {
                event.preventDefault();
                flipCard();
            }
        });

        loadSession();
    </script>
</body>
</html>