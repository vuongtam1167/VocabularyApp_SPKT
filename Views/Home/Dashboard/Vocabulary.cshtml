@using System
@using System.Linq
@using System.Text.Json
@model Vocab_LearningApp.Models.ViewModels.VocabularyPageViewModel

@{
    Layout = null;
    ViewData["Title"] = "Bộ từ vựng";

    var tags = Model.Decks
        .SelectMany(deck => (deck.Tags ?? string.Empty)
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(tag => tag)
        .ToList();

    var totalWords = Model.Decks.Sum(deck => deck.TotalWords);
    var publicDecks = Model.Decks.Count(deck => deck.IsPublic);
    var selectedTag = Model.Tag ?? string.Empty;
    var selectedSort = string.IsNullOrWhiteSpace(Model.Sort) ? "newest" : Model.Sort;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bộ từ vựng - VocabMaster</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 text-slate-900">
    <header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur">
        <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
            <a asp-controller="Home" asp-action="Dashboard" class="flex items-center gap-3">
                <span class="text-2xl">📚</span>
                <div>
                    <p class="text-sm font-bold uppercase tracking-wide text-indigo-600">VocabMaster</p>
                    <p class="text-xs text-slate-500">Vocabulary management</p>
                </div>
            </a>

            <nav class="hidden items-center gap-6 md:flex">
                <a asp-controller="Home" asp-action="Dashboard" class="text-slate-600 hover:text-slate-900">Dashboard</a>
                <a asp-controller="Home" asp-action="Vocabulary" class="font-semibold text-indigo-600">Bộ từ vựng</a>
                <a asp-controller="Home" asp-action="Progress" class="text-slate-600 hover:text-slate-900">Tiến độ</a>
            </nav>

            <div class="flex items-center gap-3">
                <img src="@(Model.User.AvatarUrl ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(Model.User.FullName)}&background=4f46e5&color=fff")"
                     alt="Avatar"
                     class="h-10 w-10 rounded-full object-cover ring-2 ring-indigo-100">
                <button type="button"
                        onclick="openDeckModal()"
                        class="rounded-2xl bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">
                    Tạo bộ từ
                </button>
            </div>
        </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <section class="mb-8 rounded-[2rem] bg-gradient-to-br from-indigo-600 via-violet-600 to-fuchsia-600 p-6 text-white shadow-xl">
            <div class="grid gap-6 lg:grid-cols-[1.5fr_1fr] lg:items-center">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-wide text-white/80">Vocabulary management</p>
                    <h1 class="mt-2 text-3xl font-black sm:text-4xl">Bộ từ vựng của bạn</h1>
                    <p class="mt-3 max-w-2xl text-white/85">
                        Tạo bộ từ, chỉnh sửa thông tin bộ, gắn tags theo chủ đề và mở chi tiết để quản lý từng từ bên trong.
                    </p>
                </div>

                <div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-1 xl:grid-cols-3">
                    <div class="rounded-2xl bg-white/15 p-4 backdrop-blur">
                        <p class="text-sm text-white/80">Tổng bộ</p>
                        <p class="mt-2 text-3xl font-black">@Model.Decks.Count</p>
                    </div>
                    <div class="rounded-2xl bg-white/15 p-4 backdrop-blur">
                        <p class="text-sm text-white/80">Tổng từ</p>
                        <p class="mt-2 text-3xl font-black">@totalWords</p>
                    </div>
                    <div class="rounded-2xl bg-white/15 p-4 backdrop-blur">
                        <p class="text-sm text-white/80">Bộ công khai</p>
                        <p class="mt-2 text-2xl font-black">@publicDecks</p>
                    </div>
                </div>
            </div>
        </section>

        <form method="get" asp-action="Vocabulary" class="mb-6 rounded-[2rem] bg-white p-4 shadow-sm ring-1 ring-slate-200">
            <div class="grid gap-4 md:grid-cols-[1.3fr_1fr_1fr_auto]">
                <input type="text"
                       name="search"
                       value="@Model.Search"
                       placeholder="Tìm kiếm bộ từ..."
                       class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">

                <select name="tag" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                    @if (string.IsNullOrWhiteSpace(selectedTag))
                    {
                        <option value="" selected>Tất cả tag</option>
                    }
                    else
                    {
                        <option value="">Tất cả tag</option>
                    }

                    @foreach (var tag in tags)
                    {
                        if (string.Equals(selectedTag, tag, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@tag" selected>@tag</option>
                        }
                        else
                        {
                            <option value="@tag">@tag</option>
                        }
                    }
                </select>

                <select name="sort" class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(selectedSort) ? "selected" : null)">Sắp xếp mặc định</option>
                    <option value="newest" selected="@(selectedSort == "newest" ? "selected" : null)">Mới nhất</option>
                    <option value="title" selected="@(selectedSort == "title" ? "selected" : null)">Tên bộ A-Z</option>
                    <option value="progress" selected="@(selectedSort == "progress" ? "selected" : null)">Tiến độ</option>
                </select>

                <div class="flex gap-3">
                    <button type="submit" class="rounded-2xl bg-indigo-600 px-5 py-3 font-semibold text-white hover:bg-indigo-700">Lọc</button>
                    <a asp-action="Vocabulary" class="rounded-2xl border border-slate-200 px-5 py-3 font-semibold text-slate-600 hover:bg-slate-50">Xóa lọc</a>
                </div>
            </div>
        </form>

        <section class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
            <div>
                <div class="mb-4 flex items-center justify-between gap-4">
                    <div>
                        <h2 class="text-2xl font-bold text-slate-900">Danh sách bộ từ</h2>
                        <p class="mt-1 text-sm text-slate-500">Mở chi tiết để thêm từ, sửa nội dung bộ hoặc bắt đầu học ngay.</p>
                    </div>
                    <span class="rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-600">@Model.Decks.Count bộ</span>
                </div>

                @if (Model.Decks.Any())
                {
                    <div class="grid gap-4 md:grid-cols-2">
                        @foreach (var deck in Model.Decks)
                        {
                            var deckData = new
                            {
                                id = deck.Id,
                                title = deck.Title,
                                description = deck.Description ?? string.Empty,
                                tags = deck.Tags ?? string.Empty,
                                isPublic = deck.IsPublic
                            };

                            <article class="rounded-[2rem] bg-white p-5 shadow-sm ring-1 ring-slate-200 transition hover:-translate-y-1 hover:shadow-lg">
                                <div class="flex items-start justify-between gap-3">
                                    <div>
                                        <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-700">@deck.PrimaryTag</span>
                                        <h3 class="mt-3 text-lg font-bold">@deck.Title</h3>
                                        <p class="mt-1 text-sm text-slate-500">@(deck.Description ?? "Chưa có mô tả")</p>
                                    </div>
                                    <span class="rounded-full @(deck.IsPublic ? "bg-emerald-50 text-emerald-700" : "bg-slate-100 text-slate-600") px-3 py-1 text-xs font-semibold">
                                        @(deck.IsPublic ? "Public" : "Private")
                                    </span>
                                </div>

                                <div class="mt-4 grid grid-cols-2 gap-3 text-sm text-slate-600">
                                    <div class="rounded-xl bg-slate-50 p-3">
                                        <span class="block text-xs text-slate-400">Tổng từ</span>
                                        <strong>@deck.TotalWords</strong>
                                    </div>
                                    <div class="rounded-xl bg-slate-50 p-3">
                                        <span class="block text-xs text-slate-400">Đang học</span>
                                        <strong>@deck.LearnedWords</strong>
                                    </div>
                                    <div class="rounded-xl bg-slate-50 p-3">
                                        <span class="block text-xs text-slate-400">Cần ôn</span>
                                        <strong>@deck.DueWords</strong>
                                    </div>
                                    <div class="rounded-xl bg-slate-50 p-3">
                                        <span class="block text-xs text-slate-400">Tiến độ</span>
                                        <strong>@deck.ProgressPercentage%</strong>
                                    </div>
                                </div>

                                <div class="mt-4 h-2 overflow-hidden rounded-full bg-slate-100">
                                    <div class="h-2 rounded-full bg-gradient-to-r from-indigo-500 to-fuchsia-500"
                                         style="width: @deck.ProgressPercentage%;"></div>
                                </div>

                                <div class="mt-4 flex flex-wrap gap-2">
                                    <a asp-controller="Home"
                                           asp-action="Vocab_detail"
                                           asp-route-deckId="@deck.Id"
                                           class="rounded-xl bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">
                                        Xem chi tiết
                                    </a>
                                    <a asp-controller="Home"
                                           asp-action="Learning"
                                           asp-route-deckId="@deck.Id"
                                           class="rounded-xl bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-200">
                                        Học ngay
                                    </a>
                                    <button type="button"
                                            onclick='openDeckModal(@Html.Raw(JsonSerializer.Serialize(deckData)))'
                                            class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-50">
                                        Sửa
                                    </button>
                                    <button type="button"
                                            onclick="deleteDeck(@deck.Id)"
                                            class="rounded-xl border border-rose-200 px-4 py-2 text-sm font-semibold text-rose-700 hover:bg-rose-50">
                                        Xóa
                                    </button>
                                </div>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <div class="rounded-[2rem] border border-dashed border-slate-300 bg-white p-10 text-center text-slate-500 shadow-sm">
                        Không tìm thấy bộ từ phù hợp. Hãy tạo bộ mới để bắt đầu học.
                    </div>
                }
            </div>

            <div class="rounded-[2rem] bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm font-semibold uppercase tracking-wide text-emerald-600">Quản lý bộ từ</p>
                <h2 class="mt-1 text-2xl font-bold">Tạo hoặc chỉnh sửa bộ</h2>

                <div class="mt-4 space-y-3 text-sm text-slate-600">
                    <div class="rounded-2xl bg-emerald-50 p-4 text-emerald-800">• Tạo bộ mới theo chủ đề IELTS, Business, Travel...</div>
                    <div class="rounded-2xl bg-emerald-50 p-4 text-emerald-800">• Chỉnh tên, mô tả, tags và trạng thái công khai bất cứ lúc nào.</div>
                    <div class="rounded-2xl bg-emerald-50 p-4 text-emerald-800">• Vào chi tiết để thêm, sửa, xóa từng từ trong bộ.</div>
                </div>

                <div class="mt-6 rounded-2xl bg-slate-50 p-4 text-sm text-slate-600">
                    Dữ liệu được cập nhật qua API nên thao tác nhanh và gọn.
                </div>
            </div>
        </section>
    </main>

    <div id="deck-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 px-4">
        <div class="w-full max-w-2xl rounded-[2rem] bg-white p-6 shadow-2xl">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-wide text-indigo-600">Deck form</p>
                    <h3 id="deck-modal-title" class="mt-1 text-2xl font-bold">Tạo bộ từ mới</h3>
                </div>
                <button type="button"
                        onclick="closeDeckModal()"
                        class="rounded-full bg-slate-100 px-3 py-1 text-slate-600 hover:bg-slate-200">
                    ×
                </button>
            </div>

            <form id="deck-form" class="mt-6 grid gap-4">
                <input type="hidden" id="deck-id">

                <div>
                    <label class="mb-2 block text-sm font-medium text-slate-700">Tên bộ từ</label>
                    <input type="text" id="deck-title-input" required
                           class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                </div>

                <div>
                    <label class="mb-2 block text-sm font-medium text-slate-700">Mô tả</label>
                    <textarea id="deck-description-input" rows="4"
                              class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200"></textarea>
                </div>

                <div class="grid gap-4 sm:grid-cols-2">
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Tags</label>
                        <input type="text" id="deck-tags-input"
                               class="w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200">
                    </div>

                    <label class="flex items-center gap-2 self-end rounded-2xl bg-slate-50 px-4 py-3 text-sm text-slate-700">
                        <input type="checkbox" id="deck-public-input" class="rounded border-slate-300 text-indigo-600 focus:ring-indigo-500">
                        Public deck
                    </label>
                </div>

                <div class="flex flex-wrap justify-end gap-3 pt-2">
                    <button type="button"
                            onclick="closeDeckModal()"
                            class="rounded-2xl border border-slate-200 px-5 py-3 font-semibold text-slate-600 hover:bg-slate-50">
                        Hủy
                    </button>
                    <button type="submit" class="rounded-2xl bg-indigo-600 px-5 py-3 font-semibold text-white hover:bg-indigo-700">
                        Lưu
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const deckModal = document.getElementById('deck-modal');
        const deckForm = document.getElementById('deck-form');
        const deckIdInput = document.getElementById('deck-id');
        const deckTitleInput = document.getElementById('deck-title-input');
        const deckDescriptionInput = document.getElementById('deck-description-input');
        const deckTagsInput = document.getElementById('deck-tags-input');
        const deckPublicInput = document.getElementById('deck-public-input');
        const deckModalTitle = document.getElementById('deck-modal-title');

        function openDeckModal(deck) {
        if (deck && deck.id) {
        deckModalTitle.textContent = 'Chỉnh sửa bộ từ';
        deckIdInput.value = deck.id;
        deckTitleInput.value = deck.title || '';
        deckDescriptionInput.value = deck.description || '';
        deckTagsInput.value = deck.tags || '';
        deckPublicInput.checked = !!deck.isPublic;
        } else {
        deckModalTitle.textContent = 'Tạo bộ từ mới';
        deckIdInput.value = '';
        deckTitleInput.value = '';
        deckDescriptionInput.value = '';
        deckTagsInput.value = '';
        deckPublicInput.checked = false;
        }

        deckModal.classList.remove('hidden');
        deckModal.classList.add('flex');
        setTimeout(() => deckTitleInput.focus(), 0);
        }

        function closeDeckModal() {
        deckModal.classList.add('hidden');
        deckModal.classList.remove('flex');
        }

        async function deleteDeck(deckId) {
        if (!confirm('Bạn chắc chắn muốn xóa bộ từ này?')) {
        return;
        }

        const response = await fetch(`/api/decks/${deckId}`, {
        method: 'DELETE'
        });

        const payload = await response.json().catch(() => null);

        if (!response.ok) {
        alert(payload?.message || 'Không thể xóa bộ từ.');
        return;
        }

        location.reload();
        }

        deckForm.addEventListener('submit', async function (event) {
        event.preventDefault();

        const deckId = deckIdInput.value.trim();
        const body = {
        title: deckTitleInput.value.trim(),
        description: deckDescriptionInput.value.trim() || null,
        tags: deckTagsInput.value.trim() || null,
        isPublic: deckPublicInput.checked
        };

        if (!body.title) {
        alert('Tên bộ từ là bắt buộc.');
        deckTitleInput.focus();
        return;
        }

        const url = deckId ? `/api/decks/${deckId}` : '/api/decks';
        const method = deckId ? 'PUT' : 'POST';

        const response = await fetch(url, {
        method,
        headers: {
        'Content-Type': 'application/json'
        },
        body: JSON.stringify(body)
        });

        const payload = await response.json().catch(() => null);

        if (!response.ok) {
        alert(payload?.message || 'Không thể lưu bộ từ.');
        return;
        }

        closeDeckModal();
        location.reload();
        });
    </script>
</body>
</html>