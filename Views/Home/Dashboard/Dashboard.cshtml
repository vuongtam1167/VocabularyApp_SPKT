@using System
@using System.Linq
@model Vocab_LearningApp.Models.ViewModels.DashboardPageViewModel
@{
    Layout = null;
    ViewData["Title"] = "Dashboard";
    var unreadNotifications = Model.Dashboard.Notifications.Count(x => !x.IsRead);
    var featuredDeck = Model.Dashboard.RecentDecks.FirstOrDefault();
    var dailyPlan = Model.Dashboard.DailyPlan;
}
@{
    var avatarUrl = Model.User?.AvatarUrl
        ?? "/images/avatars/default.jpg";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - VocabMaster</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 text-slate-900">
    <header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur">
        <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
            <a asp-controller="Home" asp-action="Dashboard" class="flex items-center gap-3">
                <span class="text-2xl">📚</span>
                <div>
                    <p class="text-sm font-bold uppercase tracking-wide text-indigo-600">VocabMaster</p>
                    <p class="text-xs text-slate-500">Dashboard</p>
                </div>
            </a>
            <nav class="hidden items-center gap-6 md:flex">
                <a asp-controller="Home" asp-action="Dashboard" class="font-semibold text-indigo-600">Dashboard</a>
                <a asp-controller="Home" asp-action="Vocabulary" class="text-slate-600 hover:text-slate-900">Bộ từ vựng</a>
                <a asp-controller="Home" asp-action="Progress" class="text-slate-600 hover:text-slate-900">Tiến độ</a>
            </nav>
            <div class="flex items-center gap-3">
                <div class="hidden text-right sm:block">
                    <p class="text-sm font-semibold">@Model.User.FullName</p>
                    <p class="text-xs text-slate-500">@Model.User.Email</p>
                </div>
                <img src="@avatarUrl" alt="Avatar" class="h-10 w-10 rounded-full object-cover ring-2 ring-indigo-100">
                <form asp-action="Logout" method="post" class="hidden md:block">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="rounded-xl border border-slate-200 px-3 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-50">Đăng xuất</button>
                </form>
            </div>
        </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <section class="mb-8 rounded-[2rem] bg-gradient-to-br from-indigo-600 via-violet-600 to-fuchsia-600 p-6 text-white shadow-xl">
            <div class="grid gap-6 lg:grid-cols-[1.5fr_1fr] lg:items-center">
                <div>
                    <div class="inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-2 text-sm backdrop-blur">
                        <span>🎯</span>
                        <span>Mục tiêu: @(Model.User.LearningGoal ?? "General English") • Level @(Model.User.CurrentLevel ?? "A1")</span>
                    </div>
                    <h1 class="mt-4 text-3xl font-black sm:text-4xl">Xin chào, @Model.User.FullName 👋</h1>
                    <p class="mt-3 max-w-2xl text-white/85">Hôm nay bạn có thể học mới, ôn lại từ đến hạn và xem ngay tiến độ học tập ở một màn hình duy nhất.</p>
                    <div class="mt-6 flex flex-wrap gap-3">
                        <a asp-controller="Home" asp-action="Vocabulary" class="rounded-2xl bg-white px-5 py-3 text-sm font-semibold text-indigo-700 transition hover:bg-indigo-50">Xem bộ từ</a>
                        <a asp-controller="Home" asp-action="Learning" asp-route-deckId="@(featuredDeck?.Id)" class="rounded-2xl border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/20">Bắt đầu học</a>
                    </div>
                </div>
                <div class="grid gap-3 sm:grid-cols-2">
                    <div class="rounded-2xl bg-white/15 p-4 backdrop-blur">
                        <p class="text-sm text-white/80">Từ cần ôn hôm nay</p>
                        <p class="mt-2 text-3xl font-black">@Model.Dashboard.Stats.DueReviewCount</p>
                    </div>
                    <div class="rounded-2xl bg-white/15 p-4 backdrop-blur">
                        <p class="text-sm text-white/80">Số từ đã học</p>
                        <p class="mt-2 text-3xl font-black">@Model.Dashboard.Stats.LearnedVocabularyCount</p>
                    </div>
                    <div class="rounded-2xl bg-white/15 p-4 backdrop-blur">
                        <p class="text-sm text-white/80">Streak hiện tại</p>
                        <p class="mt-2 text-3xl font-black">@Model.Dashboard.Stats.CurrentStreak ngày</p>
                    </div>
                    <div class="rounded-2xl bg-white/15 p-4 backdrop-blur">
                        <p class="text-sm text-white/80">Độ chính xác</p>
                        <p class="mt-2 text-3xl font-black">@Model.Dashboard.Stats.AccuracyPercentage%</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="mb-8 grid gap-4 md:grid-cols-2 xl:grid-cols-5">
            <article class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">Bộ từ</p>
                <p class="mt-2 text-3xl font-black">@Model.Dashboard.Stats.DeckCount</p>
                <p class="mt-2 text-sm text-slate-500">Bộ đang sở hữu</p>
            </article>
            <article class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">Tổng từ</p>
                <p class="mt-2 text-3xl font-black">@Model.Dashboard.Stats.TotalVocabularyCount</p>
                <p class="mt-2 text-sm text-slate-500">Toàn bộ vocab</p>
            </article>
            <article class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">Từ đã học</p>
                <p class="mt-2 text-3xl font-black">@Model.Dashboard.Stats.LearnedVocabularyCount</p>
                <p class="mt-2 text-sm text-emerald-600">Đã ghi nhận tiến độ</p>
            </article>
            <article class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">Từ thành thạo</p>
                <p class="mt-2 text-3xl font-black">@Model.Dashboard.Stats.MasteredVocabularyCount</p>
                <p class="mt-2 text-sm text-slate-500">Đã thuộc lâu dài</p>
            </article>
            <article class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200 md:col-span-2 xl:col-span-1">
                <p class="text-sm text-slate-500">Tỷ lệ đúng</p>
                <p class="mt-2 text-3xl font-black">@Model.Dashboard.Stats.AccuracyPercentage%</p>
                <p class="mt-2 text-sm text-slate-500">Accuracy trung bình</p>
            </article>
        </section>

        <section class="mb-8 grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
            <div class="rounded-[2rem] bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <div class="flex items-center justify-between gap-4">
                    <div>
                        <p class="text-sm font-semibold uppercase tracking-wide text-indigo-600">Daily learning plan</p>
                        <h2 class="mt-1 text-2xl font-bold">Kế hoạch học hôm nay</h2>
                    </div>
                    <span class="rounded-full bg-indigo-50 px-4 py-2 text-sm font-semibold text-indigo-700">Mục tiêu @Model.Dashboard.Stats.DailyTarget từ/ngày</span>
                </div>
                <div class="mt-6 grid gap-4 sm:grid-cols-3">
                    <div class="rounded-2xl bg-slate-50 p-4">
                        <p class="text-sm text-slate-500">Từ mới</p>
                        <p class="mt-2 text-3xl font-black">@dailyPlan.NewWordsTarget</p>
                        <p class="mt-1 text-sm text-slate-500">Còn lại: @dailyPlan.RemainingNewWords</p>
                    </div>
                    <div class="rounded-2xl bg-slate-50 p-4">
                        <p class="text-sm text-slate-500">Từ cần ôn</p>
                        <p class="mt-2 text-3xl font-black">@dailyPlan.DueReviewWords</p>
                        <p class="mt-1 text-sm text-slate-500">Đến hạn học</p>
                    </div>
                    <div class="rounded-2xl bg-slate-50 p-4">
                        <p class="text-sm text-slate-500">Streak</p>
                        <p class="mt-2 text-3xl font-black">@Model.Dashboard.Stats.CurrentStreak</p>
                        <p class="mt-1 text-sm text-slate-500">Chuỗi ngày liên tục</p>
                    </div>
                </div>
                <div class="mt-6 rounded-2xl bg-indigo-50 p-4 text-sm text-indigo-700">
                    Mẹo: học các từ đến hạn trước, sau đó thêm từ mới để giữ tốc độ lặp ngắt quãng ổn định.
                </div>
            </div>

            <div class="rounded-[2rem] bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <div class="flex items-center justify-between gap-4">
                    <div>
                        <p class="text-sm font-semibold uppercase tracking-wide text-fuchsia-600">Notifications</p>
                        <h2 class="mt-1 text-2xl font-bold">Nhắc học thông minh</h2>
                    </div>
                    <span class="rounded-full bg-fuchsia-50 px-4 py-2 text-sm font-semibold text-fuchsia-700">@unreadNotifications chưa đọc</span>
                </div>
                <div class="mt-6 space-y-3">
                    @if (Model.Dashboard.Notifications.Any())
                    {
                        foreach (var notification in Model.Dashboard.Notifications)
                        {
                            <div class="rounded-2xl border border-slate-200 p-4 @(notification.IsRead ? "bg-slate-50" : "bg-white")">
                                <div class="flex items-start justify-between gap-3">
                                    <div>
                                        <p class="text-sm font-semibold @(notification.IsRead ? "text-slate-500" : "text-slate-900")">@notification.Content</p>
                                        <p class="mt-1 text-xs text-slate-500">@notification.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                                    </div>
                                    @if (!notification.IsRead)
                                    {
                                        <button type="button" class="rounded-xl bg-indigo-600 px-3 py-2 text-xs font-semibold text-white hover:bg-indigo-700" onclick="markAsRead(@notification.Id)">Đã đọc</button>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="rounded-2xl border border-dashed border-slate-300 p-6 text-center text-slate-500">Chưa có thông báo mới.</div>
                    }
                </div>
            </div>
        </section>

        <section class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
            <div class="rounded-[2rem] bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <div class="flex items-center justify-between gap-4">
                    <div>
                        <p class="text-sm font-semibold uppercase tracking-wide text-indigo-600">Recent decks</p>
                        <h2 class="mt-1 text-2xl font-bold">Bộ từ gần đây</h2>
                    </div>
                    <a asp-controller="Home" asp-action="Vocabulary" class="rounded-2xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700">Xem tất cả</a>
                </div>
                <div class="mt-6 grid gap-4 md:grid-cols-2">
                    @if (Model.Dashboard.RecentDecks.Any())
                    {
                        foreach (var deck in Model.Dashboard.RecentDecks)
                        {
                            <article class="rounded-2xl border border-slate-200 p-5">
                                <div class="flex items-start justify-between gap-3">
                                    <div>
                                        <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-700">@deck.PrimaryTag</span>
                                        <h3 class="mt-3 text-lg font-bold">@deck.Title</h3>
                                        <p class="mt-1 text-sm text-slate-500">@(deck.Description ?? "Chưa có mô tả")</p>
                                    </div>
                                    <span class="rounded-full @(deck.IsPublic ? "bg-emerald-50 text-emerald-700" : "bg-slate-100 text-slate-600") px-3 py-1 text-xs font-semibold">@(deck.IsPublic ? "Public" : "Private")</span>
                                </div>
                                <div class="mt-4 grid grid-cols-2 gap-3 text-sm text-slate-600">
                                    <div class="rounded-xl bg-slate-50 p-3"><span class="block text-xs text-slate-400">Tổng từ</span><strong>@deck.TotalWords</strong></div>
                                    <div class="rounded-xl bg-slate-50 p-3"><span class="block text-xs text-slate-400">Đang học</span><strong>@deck.LearnedWords</strong></div>
                                    <div class="rounded-xl bg-slate-50 p-3"><span class="block text-xs text-slate-400">Cần ôn</span><strong>@deck.DueWords</strong></div>
                                    <div class="rounded-xl bg-slate-50 p-3"><span class="block text-xs text-slate-400">Tiến độ</span><strong>@deck.ProgressPercentage%</strong></div>
                                </div>
                                <div class="mt-4 h-2 overflow-hidden rounded-full bg-slate-100">
                                    <div class="h-2 rounded-full bg-gradient-to-r from-indigo-500 to-fuchsia-500" style="width: @deck.ProgressPercentage%;"></div>
                                </div>
                                <div class="mt-4 flex flex-wrap gap-2">
                                    <a asp-controller="Home" asp-action="Vocab_detail" asp-route-deckId="@deck.Id" class="rounded-xl bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Xem chi tiết</a>
                                    <a asp-controller="Home" asp-action="Learning" asp-route-deckId="@deck.Id" class="rounded-xl bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-200">Học ngay</a>
                                </div>
                            </article>
                        }
                    }
                    else
                    {
                        <div class="rounded-2xl border border-dashed border-slate-300 p-8 text-center text-slate-500 md:col-span-2">Chưa có bộ từ nào. Tạo bộ mới ở tab Bộ từ vựng.</div>
                    }
                </div>
            </div>

            <div class="rounded-[2rem] bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm font-semibold uppercase tracking-wide text-emerald-600">Lộ trình học</p>
                <h2 class="mt-1 text-2xl font-bold">Việc nên làm tiếp theo</h2>
                <div class="mt-6 space-y-3 text-sm text-slate-600">
                    <div class="rounded-2xl bg-emerald-50 p-4 text-emerald-800">• Học các từ đang đến hạn trước để không bị dồn bài.</div>
                    <div class="rounded-2xl bg-emerald-50 p-4 text-emerald-800">• Mở bộ từ vựng để thêm từ mới hoặc chỉnh sửa nội dung.</div>
                    <div class="rounded-2xl bg-emerald-50 p-4 text-emerald-800">• Xem lại thông báo để không bỏ lỡ lịch học hôm nay.</div>
                </div>
                <div class="mt-6 rounded-2xl bg-slate-50 p-4 text-sm text-slate-600">
                    Nhắc học và tiến độ đã được gom về một màn hình để bạn thao tác nhanh hơn.
                </div>
            </div>
        </section>
    </main>

    <script>
        async function markAsRead(notificationId) {
        const { response, payload } = await window.vocabApp.requestJson(`/api/notifications/${notificationId}/read`, {
        method: 'POST'
        });

        if (!response.ok) {
        window.vocabApp.toast(payload?.message || 'Không thể cập nhật thông báo.', 'error');
        return;
        }

        window.vocabApp.toast('Đã đánh dấu đã đọc.', 'success');
        window.vocabApp.safeReload();
        }
    </script>
</body>
</html>